<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:FitClub.Models;assembly=FitClub"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="1200"
             x:Class="FitClub.Views.TariffsView"
             Background="#F4F7F9">
             
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30" Spacing="25">
            
            <StackPanel>
                <TextBlock Text="АБОНЕМЕНТЫ И ТАРИФЫ 💳" FontSize="28" FontWeight="ExtraBold" Foreground="#2C3E50" LetterSpacing="1"/>
                <Border Height="4" Width="60" Background="#FF8955" HorizontalAlignment="Left" Margin="0,8,0,0" CornerRadius="2"/>
            </StackPanel>

            <Border Name="PassportWarningBorder" Background="#FFF3E0" CornerRadius="12" Padding="20" IsVisible="False" BorderBrush="#F39C12" BorderThickness="1">
                <StackPanel Orientation="Horizontal" Spacing="15">
                    <TextBlock Text="⚠️" FontSize="24" VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Паспортные данные не заполнены" FontSize="14" FontWeight="Bold" Foreground="#E67E22" Margin="0,0,0,4"/>
                        <TextBlock Text="Для оформления абонемента необходимо добавить данные в разделе «Мой аккаунт»." FontSize="12" Foreground="#7F8C8D"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <Border Name="ActiveSubscriptionBorder" Background="White" CornerRadius="25" BoxShadow="0 10 30 0 #15000000">
                <Grid ColumnDefinitions="12, *, Auto, 180">
                    <Border Grid.Column="0" Background="#27AE60" CornerRadius="25,0,0,25"/>
                    
                    <StackPanel Grid.Column="1" Margin="30,25" Spacing="15">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Background="#EAFaf1" CornerRadius="6" Padding="10,4">
                                <TextBlock Text="АКТИВЕН" FontSize="11" FontWeight="Black" Foreground="#27AE60"/>
                            </Border>
                            <TextBlock Text="КАРТА КЛУБА" FontSize="11" VerticalAlignment="Center" Foreground="#BDC3C7" FontWeight="Bold" LetterSpacing="2"/>
                        </StackPanel>
                        <TextBlock Text="ВАШ ТЕКУЩИЙ ТАРИФ" FontSize="18" FontWeight="Heavy" Foreground="#2C3E50"/>
                        <TextBlock Name="ActiveSubscriptionText" FontSize="13" Foreground="#5D6D7E" TextWrapping="Wrap" LineHeight="20"/>
                    </StackPanel>

                    <Border Grid.Column="2" Width="1" Background="#F2F4F4" Margin="0,30"/>

                    <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                        <Border Background="White" Padding="12" CornerRadius="12" BoxShadow="0 4 12 0 #0A000000">
                            <UniformGrid Rows="10" Columns="10" Width="80" Height="80">
                                <Border Background="#2C3E50"/><Border Background="#2C3E50"/><Border Background="#2C3E50"/><Border Background="White"/><Border Background="#2C3E50"/><Border Background="#2C3E50"/><Border Background="White"/><Border Background="#2C3E50"/><Border Background="#2C3E50"/><Border Background="#2C3E50"/>
                                <Border Background="#2C3E50"/><Border Background="White"/><Border Background="White"/><Border Background="#2C3E50"/><Border Background="White"/><Border Background="White"/><Border Background="#2C3E50"/><Border Background="White"/><Border Background="White"/><Border Background="#2C3E50"/>
                                <Border Background="#2C3E50"/><Border Background="White"/><Border Background="White"/><Border Background="#2C3E50"/><Border Background="#2C3E50"/><Border Background="#2C3E50"/><Border Background="#2C3E50"/><Border Background="White"/><Border Background="White"/><Border Background="#2C3E50"/>
                                <Border Background="White"/><Border Background="#2C3E50"/><Border Background="#2C3E50"/><Border Background="White"/><Border Background="White"/><Border Background="White"/><Border Background="White"/><Border Background="#2C3E50"/><Border Background="#2C3E50"/><Border Background="White"/>
                                <Border Background="#2C3E50"/><Border Background="White"/><Border Background="#2C3E50"/><Border Background="#2C3E50"/><Border Background="White"/><Border Background="#2C3E50"/><Border Background="#2C3E50"/><Border Background="White"/><Border Background="#2C3E50"/><Border Background="#2C3E50"/>
                                <Border Background="#2C3E50"/><Border Background="#2C3E50"/><Border Background="White"/><Border Background="White"/><Border Background="#2C3E50"/><Border Background="#2C3E50"/><Border Background="White"/><Border Background="White"/><Border Background="#2C3E50"/><Border Background="#2C3E50"/>
                                <Border Background="White"/><Border Background="#2C3E50"/><Border Background="#2C3E50"/><Border Background="White"/><Border Background="White"/><Border Background="White"/><Border Background="White"/><Border Background="#2C3E50"/><Border Background="#2C3E50"/><Border Background="White"/>
                                <Border Background="#2C3E50"/><Border Background="White"/><Border Background="White"/><Border Background="#2C3E50"/><Border Background="#2C3E50"/><Border Background="#2C3E50"/><Border Background="#2C3E50"/><Border Background="White"/><Border Background="White"/><Border Background="#2C3E50"/>
                                <Border Background="#2C3E50"/><Border Background="White"/><Border Background="White"/><Border Background="#2C3E50"/><Border Background="White"/><Border Background="White"/><Border Background="#2C3E50"/><Border Background="White"/><Border Background="White"/><Border Background="#2C3E50"/>
                                <Border Background="#2C3E50"/><Border Background="#2C3E50"/><Border Background="#2C3E50"/><Border Background="White"/><Border Background="#2C3E50"/><Border Background="#2C3E50"/><Border Background="White"/><Border Background="#2C3E50"/><Border Background="#2C3E50"/><Border Background="#2C3E50"/>
                            </UniformGrid>
                        </Border>
                        <TextBlock Text="MEMBER PASS" FontSize="9" FontWeight="Black" Foreground="#BDC3C7" HorizontalAlignment="Center" LetterSpacing="1"/>
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Spacing="15">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="🏋️" FontSize="20" VerticalAlignment="Center"/>
                    <TextBlock Text="ТРЕНАЖЕРНЫЙ ЗАЛ" FontSize="16" FontWeight="Heavy" Foreground="#2C3E50" LetterSpacing="1"/>
                    <Border Height="2" Width="40" Background="#3498DB" VerticalAlignment="Center" Margin="10,0,0,0" CornerRadius="1"/>
                </StackPanel>
                <ItemsControl Name="GymTariffsItemsControl">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="models:Tariff">
                            <Border Background="White" CornerRadius="16" Margin="0,0,15,15" Padding="15" Width="265" BoxShadow="0 4 12 0 #08000000">
                                <StackPanel Spacing="10">
                                    <Border Height="110" CornerRadius="12" ClipToBounds="True"><Image Source="{Binding TariffImage}" Stretch="UniformToFill"/></Border>
                                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="Bold" Foreground="#2C3E50" Height="40" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Price, StringFormat='{}{0:N0} ₽'}" FontSize="18" FontWeight="Heavy" Foreground="#27AE60"/>
                                    <Button Content="Оформить" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#EAFaf1" Foreground="#27AE60" FontWeight="Bold" Padding="0,10" CornerRadius="8" Click="BuyTariffButton_Click" Tag="{Binding}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <Grid ColumnDefinitions="*, *">
                <StackPanel Grid.Column="0" Spacing="15" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="👥" FontSize="20" VerticalAlignment="Center"/>
                        <TextBlock Text="ГРУППОВЫЕ" FontSize="16" FontWeight="Heavy" Foreground="#2C3E50" LetterSpacing="1"/>
                    </StackPanel>
                    <ItemsControl Name="GroupTrainingTariffsItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:Tariff">
                                <Border Background="White" CornerRadius="16" Margin="0,0,0,15" Padding="15" BoxShadow="0 4 12 0 #08000000">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="Bold" Foreground="#2C3E50"/>
                                        <TextBlock Text="{Binding Price, StringFormat='{}{0:N0} ₽'}" FontSize="18" FontWeight="Heavy" Foreground="#27AE60"/>
                                        <Button Content="Оформить" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#EBF5FB" Foreground="#3498DB" FontWeight="Bold" Padding="0,10" CornerRadius="8" Click="BuyTariffButton_Click" Tag="{Binding}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Spacing="15" Margin="10,0,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="💪" FontSize="20" VerticalAlignment="Center"/>
                        <TextBlock Text="ИНДИВИДУАЛЬНЫЕ" FontSize="16" FontWeight="Heavy" Foreground="#2C3E50" LetterSpacing="1"/>
                    </StackPanel>
                    <ItemsControl Name="IndividualTrainingTariffsItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:Tariff">
                                <Border Background="White" CornerRadius="16" Margin="0,0,0,15" Padding="15" BoxShadow="0 4 12 0 #08000000">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="Bold" Foreground="#2C3E50"/>
                                        <TextBlock Text="{Binding Price, StringFormat='{}{0:N0} ₽'}" FontSize="18" FontWeight="Heavy" Foreground="#27AE60"/>
                                        <Button Content="Оформить" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#FEF5F0" Foreground="#FF8955" FontWeight="Bold" Padding="0,10" CornerRadius="8" Click="BuyTariffButton_Click" Tag="{Binding}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>

            <StackPanel Spacing="15">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="🚀" FontSize="20" VerticalAlignment="Center"/>
                    <TextBlock Text="КОМБИНИРОВАННЫЕ ПАКЕТЫ" FontSize="16" FontWeight="Heavy" Foreground="#2C3E50" LetterSpacing="1"/>
                    <Border Height="2" Width="40" Background="#FF8955" VerticalAlignment="Center" Margin="10,0,0,0" CornerRadius="1"/>
                </StackPanel>
                <ItemsControl Name="CombinedTariffsItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="models:Tariff">
                            <Border Background="White" CornerRadius="20" Margin="0,0,0,15" Padding="25" BoxShadow="0 6 20 0 #0A000000">
                                <Grid ColumnDefinitions="Auto, *, Auto">
                                    <Border Grid.Column="0" Width="120" Height="100" CornerRadius="15" ClipToBounds="True">
                                        <Image Source="{Binding TariffImage}" Stretch="UniformToFill"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="25,0" VerticalAlignment="Center" Spacing="5">
                                        <TextBlock Text="{Binding Name}" FontSize="20" FontWeight="Heavy" Foreground="#2C3E50"/>
                                        <TextBlock Text="{Binding Description}" FontSize="13" Foreground="#7F8C8D" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding DurationDays, StringFormat='{}Период: {0} дней'}" FontSize="12" Foreground="#95A5A6" FontWeight="Bold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="10" MinWidth="180">
                                        <TextBlock Text="{Binding Price, StringFormat='{}{0:N0} ₽'}" FontSize="24" FontWeight="Black" Foreground="#27AE60" HorizontalAlignment="Right"/>
                                        <Button Content="Выбрать пакет" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#F4ECF7" Foreground="#8E44AD" FontWeight="Bold" Padding="0,12" CornerRadius="10" Click="BuyTariffButton_Click" Tag="{Binding}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>