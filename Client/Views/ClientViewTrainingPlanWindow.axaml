<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:FitClub.Models;assembly=FitClub"
        xmlns:converters="clr-namespace:FitClub.Converters"
        x:Class="FitClub.Client.Views.ClientViewTrainingPlanWindow"
        Title="Мой план тренировок"
        Width="900" Height="750"
        WindowStartupLocation="CenterOwner"
        Background="#F4F7F9">
    
    <Window.Resources>
        <converters:StringConverters x:Key="StringConverters"/>
    </Window.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30" Spacing="20">
            
            <StackPanel Margin="0,0,0,10">
                <TextBlock Text="📋 МОЙ ПЛАН ТРЕНИРОВОК" FontSize="28" FontWeight="ExtraBold" Foreground="#2C3E50" LetterSpacing="1"/>
                <Border Height="4" Width="80" Background="#9B59B6" HorizontalAlignment="Left" Margin="0,8,0,0" CornerRadius="2"/>
            </StackPanel>

            <Border Background="White" CornerRadius="12" Padding="25" BorderBrush="#E0E6ED" BorderThickness="1" BoxShadow="0 4 15 0 #05000000">
                <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto">
                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="5" Margin="0,0,0,15">
                        <TextBlock Text="Тренер и цель" FontSize="16" FontWeight="Bold" Foreground="#95A5A6"/>
                        <TextBlock x:Name="TrainerInfoText" FontSize="18" FontWeight="ExtraBold" Foreground="#2C3E50"/>
                        <TextBlock x:Name="GoalInfoText" FontSize="14" Foreground="#9B59B6" FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="5" Margin="0,0,0,15" HorizontalAlignment="Right">
                        <TextBlock Text="Детали плана" FontSize="16" FontWeight="Bold" Foreground="#95A5A6" HorizontalAlignment="Right"/>
                        <TextBlock x:Name="CreatedDateText" FontSize="14" Foreground="#7F8C8D" HorizontalAlignment="Right"/>
                        <Border x:Name="StatusBorder" CornerRadius="6" Padding="10,4" HorizontalAlignment="Right" Margin="0,5,0,0">
                            <TextBlock x:Name="StatusText" Foreground="White" FontSize="12" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>

                    <Border Grid.Row="1" Grid.ColumnSpan="2" Background="#F8F9FA" CornerRadius="8" Padding="15" BorderBrush="#E0E6ED" BorderThickness="1">
                        <StackPanel Spacing="5">
                            <TextBlock Text="Примечания тренера:" FontSize="13" FontWeight="Bold" Foreground="#7F8C8D"/>
                            <TextBlock x:Name="NotesText" FontSize="14" Foreground="#2C3E50" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Background="White" CornerRadius="12" Padding="25" BorderBrush="#E0E6ED" BorderThickness="1" BoxShadow="0 4 15 0 #05000000">
                <StackPanel Spacing="15">
                    <TextBlock Text="Программа на 12 тренировок" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>
                    
                    <ItemsControl x:Name="TrainingDaysList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:TrainingPlanDay">
                                <Border Background="#FDFEFE" CornerRadius="10" Padding="20" Margin="0,0,0,15" BorderBrush="#E0E6ED" BorderThickness="1">
                                    <StackPanel Spacing="15">
                                        <Border Background="#F5EEF8" CornerRadius="6" Padding="12,6" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding DayNumber, StringFormat='День {0}'}" FontWeight="Bold" Foreground="#8E44AD" FontSize="14"/>
                                        </Border>
                                        
                                        <ItemsControl ItemsSource="{Binding Exercises}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="models:Exercise">
                                                    <Border Background="#F8F9FA" CornerRadius="8" Padding="15" Margin="0,8,0,0" BorderBrush="#EBEDF0" BorderThickness="1">
                                                        <StackPanel Spacing="8">
                                                            <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>
                                                            
                                                            <StackPanel Orientation="Horizontal" Spacing="20">
                                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                                    <TextBlock Text="🔄" FontSize="12"/>
                                                                    <TextBlock Text="{Binding SetsDisplay}" FontSize="13" FontWeight="SemiBold" Foreground="#34495E"/>
                                                                </StackPanel>
                                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                                    <TextBlock Text="⚡" FontSize="12"/>
                                                                    <TextBlock Text="{Binding RepsDisplay}" FontSize="13" FontWeight="SemiBold" Foreground="#34495E"/>
                                                                </StackPanel>
                                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                                    <TextBlock Text="⏱️" FontSize="12"/>
                                                                    <TextBlock Text="{Binding DurationDisplay}" FontSize="13" FontWeight="SemiBold" Foreground="#34495E"/>
                                                                </StackPanel>
                                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                                    <TextBlock Text="☕" FontSize="12"/>
                                                                    <TextBlock Text="{Binding RestDisplay}" FontSize="13" FontWeight="SemiBold" Foreground="#34495E"/>
                                                                </StackPanel>
                                                            </StackPanel>

                                                            <Border Background="#F4ECF7" CornerRadius="6" Padding="10,6" Margin="0,5,0,0" IsVisible="{Binding Notes, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                                <TextBlock Text="{Binding Notes}" FontSize="12" Foreground="#8E44AD" TextWrapping="Wrap"/>
                                                            </Border>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Button Content="Закрыть" Background="#F8F9FA" Foreground="#7F8C8D" BorderBrush="#BDC3C7" BorderThickness="1" FontSize="15" FontWeight="Bold" CornerRadius="8" Padding="0,12" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Cursor="Hand" Margin="0,0,0,20" Click="OnCloseClick"/>
        </StackPanel>
    </ScrollViewer>
</Window>