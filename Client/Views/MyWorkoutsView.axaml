<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:FitClub.Views"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="800"
             x:Class="FitClub.Views.MyWorkoutsView"
             Background="#F4F7F9">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30" Spacing="25">
            
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0">
                    <TextBlock Text="МОИ ЗАПИСИ 📅" FontSize="28" FontWeight="ExtraBold" Foreground="#2C3E50" LetterSpacing="1"/>
                    <Border Height="4" Width="60" Background="#FF8955" HorizontalAlignment="Left" Margin="0,8,0,0" CornerRadius="2"/>
                </StackPanel>

                <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="15,10" BoxShadow="0 4 10 0 #08000000" ToolTip.Tip="Доступно при наличии активного абонемента">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="📋" VerticalAlignment="Center"/>
                        <Button Content="План тренировок" IsEnabled="False" Background="Transparent" Foreground="#BDC3C7" FontWeight="Bold" Padding="0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Spacing="15">
                <StackPanel Margin="0,0,0,5">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="🔥" FontSize="20" VerticalAlignment="Center"/>
                        <TextBlock Text="ПРЕДСТОЯЩИЕ ЗАНЯТИЯ" FontSize="16" FontWeight="Heavy" Foreground="#2C3E50" VerticalAlignment="Center" LetterSpacing="1"/>
                    </StackPanel>
                    <Border Height="3" Width="60" Background="#FF8955" HorizontalAlignment="Left" Margin="32,6,0,0" CornerRadius="1.5"/>
                </StackPanel>
                
                <ItemsControl Name="UpcomingWorkoutsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:WorkoutDisplayItem">
                            <Border Background="White" CornerRadius="16" Margin="0,0,15,15" Width="300" BoxShadow="0 6 15 0 #0A000000" Padding="20">
                                <StackPanel Spacing="12">
                                    <Grid ColumnDefinitions="Auto, *">
                                        <Border Grid.Column="0" Background="{Binding TypeColor}" Width="40" Height="40" CornerRadius="10">
                                            <TextBlock Text="{Binding Icon}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding TypeName}" FontSize="11" FontWeight="Bold" Foreground="#BDC3C7"/>
                                            <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>

                                    <Border Height="1" Background="#F2F4F4"/>

                                    <StackPanel Spacing="6">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="👤" Foreground="#FF8955"/>
                                            <TextBlock Text="{Binding Subtitle}" FontSize="13" Foreground="#7F8C8D" FontWeight="Medium"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="⏰" Foreground="#3498DB"/>
                                            <TextBlock Text="{Binding DateTimeRangeString}" FontSize="13" Foreground="#34495E" FontWeight="Bold"/>
                                        </StackPanel>
                                        
                                        <Border IsVisible="{Binding IsSubscriptionBooking}" Background="#EAFaf1" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" Margin="0,5,0,0">
                                            <TextBlock Text="ПО АБОНЕМЕНТУ" FontSize="9" FontWeight="Bold" Foreground="#27AE60"/>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Spacing="8">
                                        <Button Content="Предъявить QR-код" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#F4ECF7" Foreground="#8E44AD" FontWeight="Bold" FontSize="12" Padding="0,10" CornerRadius="8" Click="ShowQRCode_Click"/>
                                        <Button Content="Скачать чек" IsEnabled="True" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#F4F7F9" Foreground="#3498DB" FontWeight="Bold" FontSize="12" Padding="0,10" CornerRadius="8" Click="DownloadReceipt_Click" Tag="{Binding}"/>
                                        <Button Content="Отменить запись" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#FEF5F0" Foreground="#E74C3C" FontWeight="Bold" FontSize="12" Padding="0,10" CornerRadius="8" Click="CancelWorkout_Click" Tag="{Binding}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Name="NoUpcomingText" Text="У вас пока нет запланированных тренировок" Foreground="#BDC3C7" FontStyle="Italic" IsVisible="False" Margin="10,0"/>
            </StackPanel>

            <StackPanel Spacing="15">
                <StackPanel Margin="0,0,0,5">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="✅" FontSize="20" VerticalAlignment="Center"/>
                        <TextBlock Text="ПРОШЕДШИЕ ЗАНЯТИЯ" FontSize="16" FontWeight="Heavy" Foreground="#2C3E50" VerticalAlignment="Center" LetterSpacing="1"/>
                    </StackPanel>
                    <Border Height="3" Width="60" Background="#FF8955" HorizontalAlignment="Left" Margin="32,6,0,0" CornerRadius="1.5"/>
                </StackPanel>

                <ItemsControl Name="PastWorkoutsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:WorkoutDisplayItem">
                            <Border Background="White" CornerRadius="16" Margin="0,0,15,15" Width="300" BoxShadow="0 4 10 0 #05000000" Padding="20">
                                <StackPanel Spacing="12">
                                    <Grid ColumnDefinitions="Auto, *">
                                        <Border Grid.Column="0" Background="#F2F4F4" Width="40" Height="40" CornerRadius="10">
                                            <TextBlock Text="🏁" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding TypeName}" FontSize="11" FontWeight="Bold" Foreground="#BDC3C7"/>
                                            <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" Foreground="#7F8C8D" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>

                                    <Border Height="1" Background="#F2F4F4"/>

                                    <StackPanel Spacing="6">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="👤" Foreground="#BDC3C7"/>
                                            <TextBlock Text="{Binding Subtitle}" FontSize="13" Foreground="#95A5A6"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="⏰" Foreground="#BDC3C7"/>
                                            <TextBlock Text="{Binding DateTimeRangeString}" FontSize="13" Foreground="#95A5A6"/>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <Button Content="Оценить тренировку" IsVisible="{Binding !IsRated}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#EBF5FB" Foreground="#3498DB" FontWeight="Bold" FontSize="12" Padding="0,10" CornerRadius="8" Click="RateWorkout_Click" Tag="{Binding}"/>
                                    
                                    <StackPanel Spacing="6" IsVisible="{Binding IsRated}">
                                        <TextBlock Text="{Binding RatingText}" Foreground="#27AE60" FontWeight="Bold" HorizontalAlignment="Center" FontSize="14"/>
                                        <TextBlock Text="{Binding ReviewText}" Foreground="#34495E" FontStyle="Italic" TextWrapping="Wrap" TextAlignment="Center" FontSize="12"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>