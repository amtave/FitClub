<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FitClub.Client.Views.PassportDataWindow"
        Title="Отправка данных" Width="600" Height="850"
        WindowStartupLocation="CenterOwner" CanResize="False"
        Background="#F4F7F9">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="10" Margin="0,0,0,20">
            <TextBlock Text="ПРЕДОСТАВЛЕНИЕ ДАННЫХ" FontSize="22" FontWeight="ExtraBold" Foreground="#2C3E50" HorizontalAlignment="Center" LetterSpacing="1"/>
            <Border Height="3" Background="#3498DB" Width="80" HorizontalAlignment="Center" CornerRadius="2"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20" Margin="0,0,10,0">

                <Border Background="White" CornerRadius="12" Padding="20" BorderBrush="#E0E6ED" BorderThickness="1">
                    <StackPanel Spacing="15">
                        <TextBlock Text="1. ПАСПОРТНЫЕ ДАННЫЕ" FontSize="13" FontWeight="Bold" Foreground="#95A5A6" LetterSpacing="1"/>
                        <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto">
                            <StackPanel Grid.Column="0" Spacing="5" Margin="0,0,15,0">
                                <TextBlock Text="Серия" FontSize="12" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                <TextBox x:Name="PassportSeriesTextBox" Watermark="0000" MaxLength="4" CornerRadius="6" TextChanged="PassportSeriesTextBox_TextChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="5">
                                <TextBlock Text="Номер" FontSize="12" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                <TextBox x:Name="PassportNumberTextBox" Watermark="000000" MaxLength="6" CornerRadius="6" TextChanged="PassportNumberTextBox_TextChanged"/>
                            </StackPanel>
                        </Grid>

                        <Border Background="#F8F9FA" CornerRadius="8" Padding="15" BorderBrush="#E0E6ED" BorderThickness="1" Margin="0,10,0,0">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Фото паспорта (разворот с фото)" FontSize="12" FontWeight="SemiBold" Foreground="#2C3E50" HorizontalAlignment="Center"/>
                                <Border BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="6" Padding="5" Height="180" Background="White">
                                    <Image x:Name="PassportPhotoPreview" Stretch="Uniform"/>
                                </Border>
                                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                                    <Button x:Name="SelectPhotoButton" Content="Выбрать фото" Background="#3498DB" Foreground="White" CornerRadius="6" Padding="15,8" FontWeight="SemiBold" Click="SelectPhoto_Click"/>
                                    <Button x:Name="ClearPhotoButton" Content="Очистить" Background="#E74C3C" Foreground="White" CornerRadius="6" Padding="15,8" FontWeight="SemiBold" Click="ClearPhoto_Click" IsVisible="False"/>
                                </StackPanel>
                                <TextBlock x:Name="PhotoStatusText" FontSize="11" Foreground="#7F8C8D" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" Padding="20" BorderBrush="#E0E6ED" BorderThickness="1">
                    <StackPanel Spacing="15">
                        <TextBlock Text="2. СОГЛАСИЕ НА ОБРАБОТКУ" FontSize="13" FontWeight="Bold" Foreground="#95A5A6" LetterSpacing="1"/>
                        <TextBlock Text="Для получения услуг клуба необходимо скачать бланк согласия, распечатать, подписать его и загрузить фотографию." FontSize="12" Foreground="#7F8C8D" TextWrapping="Wrap"/>
                        
                        <Button x:Name="DownloadConsentButton" Content="📥 Скачать бланк (PDF)" Background="#F39C12" Foreground="White" CornerRadius="6" Padding="15,10" FontWeight="Bold" HorizontalAlignment="Center" Click="DownloadConsent_Click"/>
                        
                        <Border Background="#F8F9FA" CornerRadius="8" Padding="15" BorderBrush="#E0E6ED" BorderThickness="1" Margin="0,10,0,0">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Скан или фото заполненного бланка" FontSize="12" FontWeight="SemiBold" Foreground="#2C3E50" HorizontalAlignment="Center"/>
                                <Border BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="6" Padding="5" Height="180" Background="White">
                                    <Image x:Name="ConsentPhotoPreview" Stretch="Uniform"/>
                                </Border>
                                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                                    <Button x:Name="SelectConsentButton" Content="Выбрать скан" Background="#3498DB" Foreground="White" CornerRadius="6" Padding="15,8" FontWeight="SemiBold" Click="SelectConsent_Click"/>
                                    <Button x:Name="ClearConsentButton" Content="Очистить" Background="#E74C3C" Foreground="White" CornerRadius="6" Padding="15,8" FontWeight="SemiBold" Click="ClearConsent_Click" IsVisible="False"/>
                                </StackPanel>
                                <TextBlock x:Name="ConsentStatusText" FontSize="11" Foreground="#7F8C8D" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Background="#E8F6F3" CornerRadius="12" Padding="20" BorderBrush="#27AE60" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <CheckBox x:Name="ConsentCheckBox" Content="Я даю согласие на обработку моих персональных данных" Checked="ConsentCheckBox_Changed" Unchecked="ConsentCheckBox_Changed" FontWeight="Bold" Foreground="#2C3E50"/>
                        <TextBlock Text="Без вашего согласия и подписи мы не сможем проверить паспортные данные и открыть доступ к покупке абонементов." FontSize="11" Foreground="#7F8C8D" TextWrapping="Wrap" Margin="25,0,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="15" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button x:Name="CancelButton" Content="Отмена" Background="#BDC3C7" Foreground="White" Padding="30,12" FontSize="15" FontWeight="Bold" CornerRadius="8" Cursor="Hand" Click="CancelButton_Click"/>
            <Button x:Name="SubmitButton" Content="Отправить на проверку" Background="#27AE60" Foreground="White" Padding="30,12" FontSize="15" FontWeight="Bold" CornerRadius="8" Cursor="Hand" Click="SubmitButton_Click" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>