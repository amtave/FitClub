<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FitClub.Client.Views"
        Title="Смена пароля"
        Width="500"
        Height="600"
        WindowStartupLocation="CenterOwner"
        x:Class="FitClub.Client.Views.ChangePasswordWindow">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" Spacing="15">
            <TextBlock Text="🔐 Смена пароля" 
                      FontSize="20" 
                      FontWeight="Bold" 
                      Foreground="#3E5F8A"
                      HorizontalAlignment="Center"/>
            
            <!-- Текущий пароль -->
            <StackPanel x:Name="CurrentPasswordSection" Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <TextBlock Text="Текущий пароль" 
                              FontSize="12" 
                              FontWeight="SemiBold" 
                              Foreground="#2C3E50"/>
                    <Button x:Name="ForgotPasswordButton"
                            Content="Забыли пароль?"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#3498DB"
                            FontSize="10"
                            Padding="5,0"
                            HorizontalAlignment="Right"
                            Click="ForgotPasswordButton_Click"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <TextBox x:Name="CurrentPasswordTextBox"
                             Width="300"
                             PasswordChar="•"/>
                    <Button x:Name="ShowCurrentPasswordBtn"
                            Content="👁"
                            Background="Transparent"
                            BorderThickness="1"
                            BorderBrush="#BDC3C7"
                            Padding="10,5"/>
                </StackPanel>
                
                <!-- Ошибка текущего пароля -->
                <TextBlock x:Name="CurrentPasswordError"
                          Text=""
                          FontSize="10"
                          Foreground="#E74C3C"
                          IsVisible="False"/>
            </StackPanel>
            
            <!-- Новый пароль -->
            <StackPanel x:Name="NewPasswordSection" Spacing="8" IsVisible="False">
                <TextBlock Text="Новый пароль" 
                          FontSize="12" 
                          FontWeight="SemiBold" 
                          Foreground="#2C3E50"/>
                
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <TextBox x:Name="NewPasswordTextBox"
                             Width="300"
                             PasswordChar="•"/>
                    <Button x:Name="ShowNewPasswordBtn"
                            Content="👁"
                            Background="Transparent"
                            BorderThickness="1"
                            BorderBrush="#BDC3C7"
                            Padding="10,5"/>
                </StackPanel>
                
                <!-- Подсказки для пароля -->
                <Border Background="#F8F9FA" CornerRadius="8" Padding="10">
                    <StackPanel Spacing="5">
                        <TextBlock x:Name="PasswordRequirements"
                                  Text="✓ 8+ символов ✓ Заглавная ✓ Цифра ✓ Спецсимвол"
                                  FontSize="10"
                                  Foreground="#27AE60"/>
                        
                        <TextBlock x:Name="PasswordMatchText"
                                  Text=""
                                  FontSize="10"
                                  Foreground="#27AE60"/>
                    </StackPanel>
                </Border>
            </StackPanel>
            
            <!-- Подтверждение пароля -->
            <StackPanel x:Name="ConfirmPasswordSection" Spacing="8" IsVisible="False">
                <TextBlock Text="Повторите новый пароль" 
                          FontSize="12" 
                          FontWeight="SemiBold" 
                          Foreground="#2C3E50"/>
                
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <TextBox x:Name="ConfirmPasswordTextBox"
                             Width="300"
                             PasswordChar="•"/>
                    <Button x:Name="ShowConfirmPasswordBtn"
                            Content="👁"
                            Background="Transparent"
                            BorderThickness="1"
                            BorderBrush="#BDC3C7"
                            Padding="10,5"/>
                </StackPanel>
            </StackPanel>
            
            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal" 
                       Spacing="15" 
                       HorizontalAlignment="Center"
                       Margin="0,15,0,0">
                <Button x:Name="NextButton"
                        Content="Далее →"
                        Background="#3E5F8A" 
                        Foreground="White"
                        Padding="20,10"
                        Click="NextButton_Click"
                        MinWidth="120"
                        IsVisible="True"/>
                
                <Button x:Name="ChangeButton"
                        Content="✅ Сменить пароль"
                        Background="#27AE60" 
                        Foreground="White"
                        Padding="20,10"
                        Click="ChangeButton_Click"
                        MinWidth="140"
                        IsVisible="False"/>
                
                <Button Content="❌ Отмена" 
                        Background="#E74C3C" 
                        Foreground="White"
                        Padding="20,10"
                        Click="CancelButton_Click"
                        MinWidth="120"/>
            </StackPanel>
            
            <!-- Прогресс -->
            <Border Background="#F8F9FA" CornerRadius="8" Padding="10" Margin="0,10,0,0">
                <StackPanel x:Name="ProgressPanel" 
                           Orientation="Horizontal" 
                           Spacing="10" 
                           HorizontalAlignment="Center">
                    <Border Width="20" 
                            Height="20" 
                            CornerRadius="10" 
                            Background="#3E5F8A">
                        <TextBlock Text="1" 
                                  Foreground="White" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="→" 
                              Foreground="#BDC3C7"/>
                    <Border Width="20" 
                            Height="20" 
                            CornerRadius="10" 
                            Background="#BDC3C7">
                        <TextBlock Text="2" 
                                  Foreground="White" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="→" 
                              Foreground="#BDC3C7"/>
                    <Border Width="20" 
                            Height="20" 
                            CornerRadius="10" 
                            Background="#BDC3C7">
                        <TextBlock Text="3" 
                                  Foreground="White" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>