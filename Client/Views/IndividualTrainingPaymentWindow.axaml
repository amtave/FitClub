<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FitClub.Views.IndividualTrainingPaymentWindow"
        Title="Оформление записи"
        Width="550" Height="850"
        WindowStartupLocation="CenterOwner"
        Background="#F8F9FA"
        CanResize="False">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30" Spacing="25">
            
            <TextBlock Text="Оформление записи" 
                       FontSize="26" 
                       FontWeight="ExtraBold" 
                       HorizontalAlignment="Center"
                       Foreground="#2C3E50"/>
            
            <Border Background="White" CornerRadius="15" Padding="20" BoxShadow="0 4 15 0 #08000000">
                <StackPanel Spacing="8">
                    <TextBlock Name="TrainingTypeText" FontWeight="Bold" FontSize="18" Foreground="#2C3E50"/>
                    <TextBlock Name="TrainerNameText" FontSize="15" FontWeight="SemiBold" Foreground="#3498DB"/>
                    <Border Height="1" Background="#F2F4F4" Margin="0,10"/>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="📅" FontSize="16"/>
                        <TextBlock Name="TrainingDateTimeText" FontSize="14" FontWeight="SemiBold" Foreground="#7F8C8D" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,5,0,0">
                        <TextBlock Text="💳" FontSize="16"/>
                        <TextBlock Name="TrainingPriceText" FontSize="16" Foreground="#27AE60" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Name="SavedCardsSection" Background="White" CornerRadius="15" Padding="20" BoxShadow="0 4 15 0 #08000000">
                <StackPanel Spacing="15">
                    <TextBlock Text="Способ оплаты" FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>
                    
                    <StackPanel Spacing="10">
                        <ComboBox Name="SavedCardsComboBox" HorizontalAlignment="Stretch" CornerRadius="8" Height="45" SelectionChanged="SavedCardsComboBox_SelectionChanged"/>
                        
                        <Button Name="NewCardButton"
                                Content="Новая карта"
                                Background="#EBF5FB"
                                Foreground="#2980B9"
                                Click="NewCardButton_Click"
                                Padding="0,12"
                                CornerRadius="8"
                                FontWeight="Bold"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"/>
                        
                        <Border Name="SelectedCardInfo" Background="#F8F9FA" CornerRadius="10" Padding="15" IsVisible="False">
                            <Grid RowDefinitions="Auto,8,Auto" ColumnDefinitions="Auto,15,*">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Карта:" FontWeight="SemiBold" Foreground="#7F8C8D" FontSize="12"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Name="SelectedCardNumber" FontWeight="Bold" Foreground="#2C3E50" FontSize="13"/>
                                
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Срок:" FontWeight="SemiBold" Foreground="#7F8C8D" FontSize="12"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Name="SelectedCardExpiry" FontWeight="Bold" Foreground="#2C3E50" FontSize="13"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Name="BonusCardSection" Background="White" CornerRadius="15" Padding="20" BoxShadow="0 4 15 0 #08000000">
                <StackPanel Spacing="15">
                    <TextBlock Text="Бонусная программа" FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>
                    
                    <StackPanel Name="HasBonusCardPanel" Spacing="15">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Name="BonusCardInfoText" FontSize="12" FontWeight="SemiBold" Foreground="#95A5A6"/>
                                <TextBlock Name="BonusCardBalanceText" FontSize="16" FontWeight="ExtraBold" Foreground="#8E44AD"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Name="UseBonusPointsCheckBox" Content="Списать" FontWeight="Bold" Foreground="#2C3E50" Checked="UseBonusPointsCheckBox_Checked" Unchecked="UseBonusPointsCheckBox_Unchecked"/>
                        </Grid>
                        
                        <Border Name="BonusPointsSliderBorder" Background="#F4ECF7" CornerRadius="10" Padding="15" IsVisible="False">
                            <StackPanel Spacing="15">
                                <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="15">
                                    <Button Grid.Column="0" Content="- 10" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="White" Foreground="#8E44AD" CornerRadius="6" Click="DecreaseBonusPoints_Click"/>
                                    <TextBox Grid.Column="1" Name="BonusPointsTextBox" Text="0" Width="80" TextAlignment="Center" CornerRadius="6" FontWeight="Bold" TextChanged="BonusPointsTextBox_TextChanged"/>
                                    <Button Grid.Column="2" Content="+ 10" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="White" Foreground="#8E44AD" CornerRadius="6" Click="IncreaseBonusPoints_Click"/>
                                </Grid>
                                <Slider Name="BonusPointsSlider" Minimum="0" Maximum="100" TickFrequency="10" Foreground="#8E44AD" ValueChanged="BonusPointsSlider_ValueChanged"/>
                                <StackPanel Spacing="2">
                                    <TextBlock Name="BonusPointsUsedText" FontSize="12" FontWeight="SemiBold" Foreground="#95A5A6"/>
                                    <TextBlock Name="FinalPriceText" FontSize="18" FontWeight="ExtraBold" Foreground="#27AE60"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    
                    <Border Name="NoBonusCardPanel" Background="#FEF5F0" CornerRadius="10" Padding="15" IsVisible="False">
                        <TextBlock Text="Бонусная карта не оформлена. Вы можете выпустить её в личном кабинете." FontSize="12" FontWeight="SemiBold" Foreground="#D35400" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Name="NewCardSection" Background="White" CornerRadius="15" Padding="20" BoxShadow="0 4 15 0 #08000000" IsVisible="False">
                <StackPanel Spacing="15">
                    <Button Name="BackButton" Content="← Вернуться к сохраненным" Background="Transparent" Foreground="#7F8C8D" FontWeight="Bold" Click="BackToSavedCardsButton_Click" Padding="0"/>
                    <TextBlock Text="Данные новой карты" FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>
                    <StackPanel Spacing="5">
                        <TextBlock Text="Номер карты" FontSize="12" FontWeight="SemiBold" Foreground="#95A5A6"/>
                        <TextBox Name="CardNumberTextBox" Watermark="0000 0000 0000 0000" CornerRadius="8" Height="45" TextChanged="CardNumberTextBox_TextChanged" MaxLength="19"/>
                    </StackPanel>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                        <StackPanel Grid.Column="0" Spacing="5">
                            <TextBlock Text="Срок действия" FontSize="12" FontWeight="SemiBold" Foreground="#95A5A6"/>
                            <TextBox Name="ExpiryDateTextBox" Watermark="ММ/ГГ" CornerRadius="8" Height="45" TextChanged="ExpiryDateTextBox_TextChanged" MaxLength="5"/>
                            <TextBlock Name="ExpiryDateErrorText" FontSize="10" Foreground="#E74C3C" IsVisible="False"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="5">
                            <TextBlock Text="CVV" FontSize="12" FontWeight="SemiBold" Foreground="#95A5A6"/>
                            <TextBox Name="CvvTextBox" Watermark="000" CornerRadius="8" Height="45" TextChanged="CvvTextBox_TextChanged" MaxLength="3" PasswordChar="*"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Button Name="PayButton" Content="Оплатить" Background="#27AE60" Foreground="White" FontSize="16" FontWeight="Bold" Height="50" CornerRadius="10" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="PayButton_Click" IsEnabled="False"/>
            
            <Border Name="LoadingBorder" Background="#F8F9FA" CornerRadius="10" Padding="20" IsVisible="False">
                <StackPanel HorizontalAlignment="Center" Spacing="15">
                    <ProgressBar IsIndeterminate="True" Height="6" Width="200" Foreground="#3498DB" CornerRadius="3"/>
                    <TextBlock Text="Обработка транзакции..." FontSize="14" FontWeight="Bold" Foreground="#7F8C8D" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            
            <Border Name="SuccessBorder" Background="#EAFaf1" BorderBrush="#27AE60" BorderThickness="2" CornerRadius="15" Padding="25" IsVisible="False">
                <StackPanel HorizontalAlignment="Center" Spacing="10">
                    <TextBlock Text="✅" FontSize="40" HorizontalAlignment="Center"/>
                    <TextBlock Text="Успешно оплачено!" FontSize="18" FontWeight="ExtraBold" Foreground="#27AE60" HorizontalAlignment="Center"/>
                    <Button Name="CloseButton" Content="Отлично" Background="#27AE60" Foreground="White" CornerRadius="8" FontWeight="Bold" Click="CloseButton_Click" Padding="30,10" Margin="0,15,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Button Name="CancelButton" Content="Отменить" Background="Transparent" Foreground="#95A5A6" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Click="CancelButton_Click"/>
        </StackPanel>
    </ScrollViewer>
</Window>