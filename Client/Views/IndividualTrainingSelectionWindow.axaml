<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:FitClub.Models;assembly=FitClub"
        x:Class="FitClub.Views.IndividualTrainingSelectionWindow"
        Title="Персональный абонемент" Width="900" Height="700"
        WindowStartupLocation="CenterOwner" Background="#F4F7F9">
    
    <Grid RowDefinitions="Auto, *">
        <Border Grid.Row="0" Background="White" Padding="25" BoxShadow="0 4 20 0 #10000000">
            <StackPanel Spacing="5">
                <TextBlock Text="ИНДИВИДУАЛЬНАЯ ПРОГРАММА 💎" FontSize="22" FontWeight="Heavy" Foreground="#2C3E50" HorizontalAlignment="Center"/>
                <TextBlock Text="Персональный наставник и направление для максимального результата" FontSize="13" Foreground="#95A5A6" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*, *">
            <StackPanel Grid.Column="0" Margin="20" Spacing="15">
                <TextBlock Text="1. ВЫБЕРИТЕ СПЕЦИАЛИЗАЦИЮ" FontSize="14" FontWeight="Bold" Foreground="#2C3E50"/>
                <ScrollViewer Height="480">
                    <ListBox Name="TypesList" Background="Transparent" BorderThickness="0" SelectionChanged="TypesList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:TrainingType">
                                <Border Background="White" CornerRadius="12" Padding="15" Margin="0,0,5,10" BoxShadow="0 2 8 0 #05000000">
                                    <Grid ColumnDefinitions="Auto, *">
                                        <Border Grid.Column="0" Width="50" Height="50" Background="#FEF5F0" CornerRadius="8">
                                            <TextBlock Text="💪" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#2C3E50" FontSize="15"/>
                                            <TextBlock Text="Индивидуальный формат" FontSize="11" Foreground="#E67E22"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </StackPanel>

            <Border Grid.Column="1" Background="White" Padding="20">
                <StackPanel Spacing="15">
                    <TextBlock Text="2. ВАШ ПЕРСОНАЛЬНЫЙ ТРЕНЕР" FontSize="14" FontWeight="Bold" Foreground="#2C3E50"/>
                    <ScrollViewer Height="480">
                        <ItemsControl Name="TrainersItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:Trainer">
                                    <Button Background="Transparent" Padding="0" Margin="0,0,5,12" Click="TrainerSelect_Click" HorizontalAlignment="Stretch" BorderThickness="0" Tag="{Binding}">
                                        <Border Name="TrainerCard" Background="#F8F9FA" CornerRadius="12" Padding="15" BorderBrush="#E0E6ED" BorderThickness="1">
                                            <Grid ColumnDefinitions="Auto, *">
                                                <Border Grid.Column="0" Width="60" Height="60" CornerRadius="30" ClipToBounds="True">
                                                    <Image Source="{Binding PhotoBitmap}" Stretch="UniformToFill"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FullName}" FontWeight="Bold" Foreground="#2C3E50"/>
                                                    <TextBlock Text="{Binding Specialization}" FontSize="12" Foreground="#7F8C8D"/>
                                                    <TextBlock Text="{Binding ExperienceInfo}" FontSize="11" Foreground="#3498DB" FontWeight="Bold"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <StackPanel Name="EmptyTrainersPanel" IsVisible="False" Margin="0,50" Spacing="10">
                        <TextBlock Text="🔍" FontSize="40" HorizontalAlignment="Center" Opacity="0.3"/>
                        <TextBlock Text="Выберите специализацию" FontSize="14" Foreground="#BDC3C7" HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="1" VerticalAlignment="Bottom" Background="White" Padding="20" BorderBrush="#F2F4F4" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*, Auto">
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Name="SelectionStatusText" Text="Ожидание выбора специализации..." FontSize="13" Foreground="#E74C3C" FontWeight="Medium"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                    <Button Content="Отмена" Click="Cancel_Click" Background="#F2F4F4" Foreground="#7F8C8D" Padding="20,10" CornerRadius="8"/>
                    <Button Name="ConfirmButton" Content="Оформить абонемент" Click="Confirm_Click" IsEnabled="False" Background="#3498DB" Foreground="White" Padding="30,10" CornerRadius="8" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>