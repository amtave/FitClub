<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:FitClub.Models;assembly=FitClub"
        xmlns:local="clr-namespace:FitClub.Client.Views;assembly=FitClub"
        x:Class="FitClub.Client.Views.TrainerGroupTrainingBookingWindow"
        Title="Запись на групповую тренировку" Width="950" Height="750"
        WindowStartupLocation="CenterOwner" CanResize="False"
        Background="#F4F7F9">
    
    <Grid RowDefinitions="Auto, *">
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E6ED" BorderThickness="0,0,0,1">
            <StackPanel>
                <Border Padding="20">
                    <Grid ColumnDefinitions="Auto, *, Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="15">
                            <Border Width="50" Height="50" CornerRadius="25" ClipToBounds="True">
                                <Image x:Name="TrainerPhoto" Stretch="UniformToFill"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="TrainerNameText" FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>
                                <TextBlock x:Name="TrainerSpecText" FontSize="12" Foreground="#FF8955" FontWeight="SemiBold"/>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="ГРУППОВЫЕ ЗАНЯТИЯ" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" FontWeight="ExtraBold" Foreground="#95A5A6" LetterSpacing="1"/>
                        <Button Grid.Column="2" Content="✕" Click="CloseClick" Background="Transparent" Foreground="#BDC3C7" FontSize="20"/>
                    </Grid>
                </Border>

                <Border Background="#FDFEFE" Margin="20,0,20,20" CornerRadius="12" BorderBrush="#EBEDF0" BorderThickness="1">
                    <Grid ColumnDefinitions="250, *">
                        <Border Grid.Column="0" Height="150" CornerRadius="12,0,0,12" ClipToBounds="True" Background="#F2F4F4">
                            <Image x:Name="TrainingImage" Stretch="UniformToFill"/>
                        </Border>
                        <Border Grid.Column="1" Padding="20">
                            <StackPanel Spacing="8">
                                <TextBlock x:Name="TrainingTitleText" FontSize="22" FontWeight="Heavy" Foreground="#2C3E50" Text="Выберите направление"/>
                                <TextBlock x:Name="TrainingDescText" FontSize="13" Foreground="#7F8C8D" TextWrapping="Wrap" MaxLines="4" Text="Выберите подходящую дату в календаре, чтобы увидеть доступные тренировки тренера."/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="400, *">
            <Border Grid.Column="0" Background="White" Margin="20" CornerRadius="12" BoxShadow="0 2 10 0 #10000000" Padding="15">
                <StackPanel Spacing="15">
                    <Grid ColumnDefinitions="Auto, *, Auto">
                        <Button Grid.Column="0" Content="◀" Click="PrevMonthClick" Background="Transparent" Foreground="#3498DB" FontWeight="Bold"/>
                        <TextBlock x:Name="MonthText" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>
                        <Button Grid.Column="2" Content="▶" Click="NextMonthClick" Background="Transparent" Foreground="#3498DB" FontWeight="Bold"/>
                    </Grid>

                    <UniformGrid Columns="7">
                        <TextBlock Text="Пн" HorizontalAlignment="Center" FontSize="11" Foreground="#BDC3C7" FontWeight="Bold"/>
                        <TextBlock Text="Вт" HorizontalAlignment="Center" FontSize="11" Foreground="#BDC3C7" FontWeight="Bold"/>
                        <TextBlock Text="Ср" HorizontalAlignment="Center" FontSize="11" Foreground="#BDC3C7" FontWeight="Bold"/>
                        <TextBlock Text="Чт" HorizontalAlignment="Center" FontSize="11" Foreground="#BDC3C7" FontWeight="Bold"/>
                        <TextBlock Text="Пт" HorizontalAlignment="Center" FontSize="11" Foreground="#BDC3C7" FontWeight="Bold"/>
                        <TextBlock Text="Сб" HorizontalAlignment="Center" FontSize="11" Foreground="#E74C3C" FontWeight="Bold"/>
                        <TextBlock Text="Вс" HorizontalAlignment="Center" FontSize="11" Foreground="#E74C3C" FontWeight="Bold"/>
                    </UniformGrid>

                    <ItemsControl x:Name="CalendarControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><UniformGrid Columns="7"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:BookingCalendarDay">
                                <Button Classes="DayBtn" Click="DayClick" IsEnabled="{Binding IsEnabled}" Width="45" Height="45" Margin="2" CornerRadius="22.5" BorderBrush="{Binding BorderColor}" BorderThickness="{Binding BorderThickness}">
                                    <Button.Styles>
                                        <Style Selector="Button.DayBtn">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="#2C3E50"/>
                                        </Style>
                                        <Style Selector="Button.DayBtn[IsDefault=True]">
                                            <Setter Property="Background" Value="#3498DB"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Style>
                                    </Button.Styles>
                                    <Button.IsDefault><Binding Path="IsSelected"/></Button.IsDefault>
                                    <TextBlock Text="{Binding Day}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" RowDefinitions="Auto, *" Margin="0,20,20,20">
                <TextBlock Grid.Row="0" x:Name="SelectedDateText" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>
                <ScrollViewer Grid.Row="1">
                    <StackPanel>
                        <ItemsControl x:Name="SlotsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:TrainingSchedule">
                                    <Border Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,12" BorderBrush="#E0E6ED" BorderThickness="1">
                                        <Grid ColumnDefinitions="Auto, *, Auto">
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding TrainingTime, StringFormat='{}{0:hh\\:mm}'}" FontSize="20" FontWeight="Heavy" Foreground="#2C3E50"/>
                                                <TextBlock Text="Начало" FontSize="10" Foreground="#BDC3C7" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="20,0" VerticalAlignment="Center" Spacing="4">
                                                <TextBlock Text="{Binding GroupTraining.Name}" FontSize="15" FontWeight="Bold" Foreground="#34495E"/>
                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                    <Border Background="#FEF5EE" CornerRadius="4" Padding="6,2">
                                                        <TextBlock Text="{Binding OccupiedSlotsFormatted}" FontSize="11" Foreground="#E67E22" FontWeight="Bold"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding GroupTraining.Price, StringFormat='{}{0:N0} ₽'}" FontSize="14" Foreground="#27AE60" FontWeight="Bold"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <Button Grid.Column="2" Content="Записаться" Click="BookSlotClick" Tag="{Binding}" Background="#EAFaf1" Foreground="#27AE60" BorderBrush="#27AE60" BorderThickness="1" Padding="15,10" CornerRadius="8" FontWeight="Bold"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel x:Name="NoSlotsPanel" IsVisible="False" Margin="0,60,0,0" Spacing="10">
                            <TextBlock Text="📭" FontSize="40" HorizontalAlignment="Center"/>
                            <TextBlock Text="Нет доступных занятий на эту дату" FontSize="14" Foreground="#95A5A6" HorizontalAlignment="Center" FontStyle="Italic"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>