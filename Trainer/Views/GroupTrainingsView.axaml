<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:FitClub.Models;assembly=FitClub"
             xmlns:local="clr-namespace:FitClub.Trainer.Views;assembly=FitClub"
             x:Class="FitClub.Trainer.Views.GroupTrainingsView">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" Spacing="20">
            <TextBlock Text="Групповые занятия" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="#2C3E50"/>
            
            <!-- Информация о тренере -->
            <Border Background="#E8F6F3" CornerRadius="8" Padding="15">
                <StackPanel>
                    <TextBlock Name="TrainerInfoText"
                              FontSize="14" 
                              FontWeight="SemiBold"
                              Foreground="#2C3E50"
                              Text="Загрузка информации о тренере..."/>
                </StackPanel>
            </Border>

            <!-- Календарь -->
            <Border BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="8" Padding="15">
                <StackPanel Spacing="15">
                    <!-- НАВИГАЦИЯ ПО МЕСЯЦАМ -->
                    <Grid ColumnDefinitions="*,Auto,*">
                        <Button Grid.Column="0" 
                                Content="◀ Предыдущий" 
                                HorizontalAlignment="Left"
                                Click="PreviousMonth_Click"/>
                        
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                            <Button Content="Текущий месяц" 
                                    Click="CurrentMonth_Click"/>
                        </StackPanel>
                        
                        <Button Grid.Column="2" 
                                Content="Следующий ▶" 
                                HorizontalAlignment="Right"
                                Click="NextMonth_Click"/>
                    </Grid>
                    
                    <TextBlock Text="Календарь групповых занятий" 
                              FontSize="16" 
                              FontWeight="Bold"
                              Foreground="#2C3E50"/>
                    
                    <!-- Легенда -->
                    <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <Border Width="15" Height="15" Background="#46C471" CornerRadius="3"/>
                            <TextBlock Text="Свободный день" FontSize="10"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <Border Width="15" Height="15" Background="#3498DB" CornerRadius="3"/>
                            <TextBlock Text="Есть занятия" FontSize="10"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <Border Width="15" Height="15" Background="#F39C12" CornerRadius="3"/>
                            <TextBlock Text="Выбрано" FontSize="10"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <Border Width="15" Height="15" Background="#95A5A6" CornerRadius="3"/>
                            <TextBlock Text="Не рабочий" FontSize="10"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- Дни недели -->
                    <Grid ColumnDefinitions="70,70,70,70,70,70,70" Margin="0,10,0,0">
                        <TextBlock Grid.Column="0" Text="Пн" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" Text="Вт" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Grid.Column="2" Text="Ср" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Grid.Column="3" Text="Чт" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Grid.Column="4" Text="Пт" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Grid.Column="5" Text="Сб" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Grid.Column="6" Text="Вс" HorizontalAlignment="Center" FontWeight="Bold"/>
                    </Grid>

                    <!-- Сетка календаря -->
                    <Grid x:Name="CalendarGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="70"/>
                            <RowDefinition Height="70"/>
                            <RowDefinition Height="70"/>
                            <RowDefinition Height="70"/>
                            <RowDefinition Height="70"/>
                            <RowDefinition Height="70"/>
                        </Grid.RowDefinitions>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Выбранная дата и групповые тренировки -->
            <Border BorderBrush="#3498DB" BorderThickness="2" CornerRadius="8" Padding="15"
                   Name="SelectedDateBorder" IsVisible="False">
                <StackPanel Spacing="10">
                    <TextBlock Name="SelectedDateText"
                              FontSize="16" 
                              FontWeight="Bold"
                              Foreground="#2C3E50"/>
                    
                    <!-- ItemsControl для отображения групповых тренировок -->
                    <ItemsControl Name="GroupTrainingsItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:GroupTrainingViewModel">
                                <Border Background="#F8F9FA" 
                                       CornerRadius="8" 
                                       Padding="15" 
                                       Margin="0,5"
                                       BorderBrush="#BDC3C7"
                                       BorderThickness="1">
                                    <Grid ColumnDefinitions="120,*,100,100,150">
                                        <!-- Время тренировки -->
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0">
                                            <TextBlock Text="{Binding TimeFormatted}"
                                                      FontSize="14"
                                                      FontWeight="Bold"
                                                      Foreground="#2C3E50"
                                                      TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding DurationFormatted}"
                                                      FontSize="11"
                                                      Foreground="#7F8C8D"
                                                      FontStyle="Italic"
                                                      Margin="0,2,0,0"/>
                                        </StackPanel>
                                        
                                        <!-- Информация о тренировке -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,10,0">
                                            <TextBlock Text="{Binding TrainingName}"
                                                      FontSize="13"
                                                      FontWeight="SemiBold"
                                                      Foreground="#2C3E50"/>
                                            <TextBlock Text="{Binding TrainingDescription}"
                                                      FontSize="11"
                                                      Foreground="#7F8C8D"
                                                      TextWrapping="Wrap"
                                                      Margin="0,2,0,0"
                                                      MaxHeight="40"
                                                      TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        
                                        <!-- Участники -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,10,0">
                                            <TextBlock Text="{Binding ParticipantsInfo}"
                                                      FontSize="13"
                                                      FontWeight="Bold"
                                                      Foreground="#27AE60"
                                                      HorizontalAlignment="Center"/>
                                            <TextBlock Text="участников"
                                                      FontSize="9"
                                                      Foreground="#7F8C8D"
                                                      HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        
                                        <!-- Интенсивность -->
                                        <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="0,0,10,0">
                                            <TextBlock Text="{Binding IntensityLevel}"
                                                      FontSize="11"
                                                      FontWeight="SemiBold"
                                                      Foreground="#E74C3C"
                                                      HorizontalAlignment="Center"/>
                                            <TextBlock Text="интенсивность"
                                                      FontSize="9"
                                                      Foreground="#7F8C8D"
                                                      HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        
                                        <!-- Кнопка открыть -->
                                        <Button Grid.Column="4" 
                                                Content="Открыть"
                                                Background="#3498DB"
                                                Foreground="White"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Padding="15,8"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Center"
                                                Command="{Binding OpenTrainingCommand}"
                                                Tag="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Сообщение если нет тренировок -->
                    <TextBlock Name="NoTrainingsMessage"
                              Text="На выбранную дату нет групповых занятий"
                              FontSize="12"
                              Foreground="#7F8C8D"
                              FontStyle="Italic"
                              HorizontalAlignment="Center"
                              IsVisible="False"/>
                </StackPanel>
            </Border>

            <!-- Сообщение если дата не выбрана -->
            <Border Background="#FFF9E6" CornerRadius="8" Padding="15"
                   Name="NoDateSelectedBorder">
                <TextBlock Text="Выберите дату в календаре для просмотра групповых занятий"
                          FontSize="12"
                          Foreground="#E67E22"
                          HorizontalAlignment="Center"/>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>