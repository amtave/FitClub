<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FitClub.Trainer.Views.TrainerChangePasswordWindow"
        Title="Смена пароля"
        Width="500" Height="480"
        WindowStartupLocation="CenterOwner"
        Background="#F4F7F9"
        CanResize="False">

    <StackPanel Margin="30" Spacing="25">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
            <TextBlock Text="🔐" FontSize="26" VerticalAlignment="Center"/>
            <TextBlock Text="Смена пароля" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>
        </StackPanel>

        <Border x:Name="Step1Panel" Background="White" CornerRadius="12" Padding="25" BorderBrush="#E0E6ED" BorderThickness="1" BoxShadow="0 4 15 0 #05000000">
            <StackPanel Spacing="15">
                <Grid ColumnDefinitions="Auto, *">
                    <TextBlock Grid.Column="0" Text="Текущий пароль" FontSize="14" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Забыли пароль?" Background="Transparent" Foreground="#3498DB" FontSize="13" HorizontalAlignment="Right" Padding="0" Cursor="Hand" Click="ForgotPassword_Click"/>
                </Grid>
                
                <TextBox x:Name="CurrentPasswordBox" PasswordChar="•" FontSize="14" CornerRadius="8" Padding="12" BorderBrush="#BDC3C7">
                    <TextBox.InnerRightContent>
                        <Button Content="👁" Background="Transparent" Foreground="#7F8C8D" BorderThickness="0" FontSize="16" Padding="10,0" VerticalAlignment="Stretch" VerticalContentAlignment="Center" Cursor="Hand" Click="ToggleCurrentPassword_Click"/>
                    </TextBox.InnerRightContent>
                </TextBox>
                
                <TextBlock x:Name="Step1ErrorText" Foreground="#E74C3C" FontSize="12" IsVisible="False"/>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,10,0,0">
                    <Button Grid.Column="0" Content="Далее →" Background="#3E5F8A" Foreground="White" FontWeight="Bold" CornerRadius="8" Padding="0,12" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Cursor="Hand" Click="Step1Next_Click"/>
                    <Button Grid.Column="1" Content="✕ Отмена" Background="#E74C3C" Foreground="White" FontWeight="Bold" CornerRadius="8" Padding="0,12" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Cursor="Hand" Click="Cancel_Click"/>
                </Grid>
            </StackPanel>
        </Border>

        <Border x:Name="Step2Panel" Background="White" CornerRadius="12" Padding="25" BorderBrush="#E0E6ED" BorderThickness="1" BoxShadow="0 4 15 0 #05000000" IsVisible="False">
            <StackPanel Spacing="15">
                <Border Background="#EAFaf1" CornerRadius="8" Padding="15">
                    <StackPanel Spacing="5">
                        <TextBlock Text="✉️ Код отправлен на email" FontWeight="Bold" Foreground="#27AE60"/>
                        <TextBlock x:Name="EmailDisplayText" Foreground="#2C3E50" FontSize="13"/>
                        <TextBlock Text="Введите 6-значный код из письма:" FontSize="13" Foreground="#7F8C8D" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="Код подтверждения" FontSize="14" FontWeight="Bold" Foreground="#2C3E50"/>
                <TextBox x:Name="VerificationCodeBox" FontSize="18" FontWeight="Bold" TextAlignment="Center" CornerRadius="8" Padding="12" BorderBrush="#9B59B6" BorderThickness="2" MaxLength="6"/>
                
                <TextBlock x:Name="TimerText" Foreground="#E74C3C" FontSize="12" HorizontalAlignment="Center"/>
                <TextBlock x:Name="Step2ErrorText" Foreground="#E74C3C" FontSize="12" HorizontalAlignment="Center" IsVisible="False"/>

                <Grid ColumnDefinitions="*, *, *" ColumnSpacing="10" Margin="0,10,0,0">
                    <Button Grid.Column="0" Content="✓ Продолжить" Background="#27AE60" Foreground="White" FontWeight="Bold" CornerRadius="8" Padding="0,12" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontSize="12" Cursor="Hand" Click="Step2Next_Click"/>
                    <Button Grid.Column="1" x:Name="ResendCodeBtn" Content="Отправить повторно" Background="#3498DB" Foreground="White" FontWeight="Bold" CornerRadius="8" Padding="0,12" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontSize="11" IsEnabled="False" Cursor="Hand" Click="ResendCode_Click"/>
                    <Button Grid.Column="2" Content="✕ Отмена" Background="#E74C3C" Foreground="White" FontWeight="Bold" CornerRadius="8" Padding="0,12" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontSize="12" Cursor="Hand" Click="Cancel_Click"/>
                </Grid>
            </StackPanel>
        </Border>

        <Border x:Name="Step3Panel" Background="White" CornerRadius="12" Padding="25" BorderBrush="#E0E6ED" BorderThickness="1" BoxShadow="0 4 15 0 #05000000" IsVisible="False">
            <StackPanel Spacing="15">
                <Grid ColumnDefinitions="Auto, *">
                    <TextBlock Grid.Column="0" Text="Новый пароль" FontSize="14" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Сгенерировать" Background="Transparent" Foreground="#3498DB" FontSize="13" HorizontalAlignment="Right" Padding="0" Cursor="Hand" Click="GeneratePassword_Click"/>
                </Grid>
                
                <TextBox x:Name="NewPasswordBox" PasswordChar="•" FontSize="14" CornerRadius="8" Padding="12" BorderBrush="#9B59B6" KeyUp="NewPasswordBox_KeyUp">
                    <TextBox.InnerRightContent>
                        <Button Content="👁" Background="Transparent" Foreground="#7F8C8D" BorderThickness="0" FontSize="16" Padding="10,0" VerticalAlignment="Stretch" VerticalContentAlignment="Center" Cursor="Hand" Click="ToggleNewPassword_Click"/>
                    </TextBox.InnerRightContent>
                </TextBox>
                
                <Border Background="#F8F9FA" CornerRadius="6" Padding="10">
                    <TextBlock x:Name="PasswordHintText" Text="✕ 8+ символов ✕ Заглавная ✕ Цифра ✕ Спецсимвол" FontSize="11" Foreground="#E74C3C"/>
                </Border>

                <TextBlock Text="Повторите новый пароль" FontSize="14" FontWeight="Bold" Foreground="#2C3E50" Margin="0,5,0,0"/>
                <TextBox x:Name="ConfirmPasswordBox" PasswordChar="•" FontSize="14" CornerRadius="8" Padding="12" BorderBrush="#BDC3C7">
                    <TextBox.InnerRightContent>
                        <Button Content="👁" Background="Transparent" Foreground="#7F8C8D" BorderThickness="0" FontSize="16" Padding="10,0" VerticalAlignment="Stretch" VerticalContentAlignment="Center" Cursor="Hand" Click="ToggleConfirmPassword_Click"/>
                    </TextBox.InnerRightContent>
                </TextBox>
                
                <TextBlock x:Name="Step3ErrorText" Foreground="#E74C3C" FontSize="12" HorizontalAlignment="Center" IsVisible="False"/>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,10,0,0">
                    <Button Grid.Column="0" x:Name="FinishChangeBtn" Content="✓ Сменить пароль" Background="#27AE60" Foreground="White" FontWeight="Bold" CornerRadius="8" Padding="0,12" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Cursor="Hand" Click="FinishChange_Click" IsEnabled="False"/>
                    <Button Grid.Column="1" Content="✕ Отмена" Background="#E74C3C" Foreground="White" FontWeight="Bold" CornerRadius="8" Padding="0,12" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Cursor="Hand" Click="Cancel_Click"/>
                </Grid>
            </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15">
            <Border x:Name="Step1Dot" Width="24" Height="24" CornerRadius="12" Background="#3E5F8A">
                <TextBlock Text="1" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="→" Foreground="#BDC3C7" VerticalAlignment="Center"/>
            <Border x:Name="Step2Dot" Width="24" Height="24" CornerRadius="12" Background="#BDC3C7">
                <TextBlock Text="2" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="→" Foreground="#BDC3C7" VerticalAlignment="Center"/>
            <Border x:Name="Step3Dot" Width="24" Height="24" CornerRadius="12" Background="#BDC3C7">
                <TextBlock Text="3" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </StackPanel>
    </StackPanel>
</Window>