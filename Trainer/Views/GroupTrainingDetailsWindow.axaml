<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:FitClub.Models;assembly=FitClub"
        xmlns:local="clr-namespace:FitClub.Trainer.Views;assembly=FitClub"
        x:Class="FitClub.Trainer.Views.GroupTrainingDetailsWindow"
        Title="Детали групповой тренировки" Width="800" Height="650"
        WindowStartupLocation="CenterOwner" CanResize="False"
        Background="#F4F7F9">
    
    <Grid RowDefinitions="Auto, *">
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E6ED" BorderThickness="0,0,0,1" Padding="25">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="TrainingTimeText" FontSize="24" FontWeight="Heavy" Foreground="#3498DB"/>
                    <TextBlock x:Name="TrainingDateText" FontSize="14" Foreground="#7F8C8D" FontWeight="Bold" Margin="0,2,0,0"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="30,0">
                    <TextBlock x:Name="TrainingNameText" FontSize="22" FontWeight="Bold" Foreground="#2C3E50"/>
                    <TextBlock x:Name="TrainingStatsText" FontSize="14" Foreground="#E67E22" FontWeight="SemiBold" Margin="0,4,0,0"/>
                </StackPanel>
                
                <Button Grid.Column="2" Content="✕" Click="CloseClick" Background="Transparent" Foreground="#BDC3C7" FontSize="24" FontWeight="Bold" Cursor="Hand"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Margin="25" Padding="25" BoxShadow="0 4 15 0 #05000000" BorderBrush="#E0E6ED" BorderThickness="1">
            <Grid RowDefinitions="Auto, *">
                <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,20">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Список участников" FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>
                        <Border Height="3" Width="40" Background="#FF8955" HorizontalAlignment="Left" Margin="0,5,0,0" CornerRadius="1.5"/>
                    </StackPanel>
                    
                    <Button Grid.Column="1" Content="⬇ Скачать список" Click="DownloadList_Click" Background="#F8F9FA" Foreground="#3498DB" BorderBrush="#3498DB" BorderThickness="1" CornerRadius="6" Padding="15,8" FontWeight="Bold" Cursor="Hand"/>
                </Grid>

                <ScrollViewer Grid.Row="1">
                    <StackPanel>
                        <ItemsControl x:Name="ClientsItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:ClientBookingItem">
                                    <Border Background="#FDFEFE" BorderBrush="#EBEDF0" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                        <Grid ColumnDefinitions="Auto, *, Auto">
                                            <Border Grid.Column="0" Width="50" Height="50" CornerRadius="25" Background="#EAF2F8" ClipToBounds="True" Margin="0,0,15,0">
                                                <Image Source="{Binding AvatarBitmap}" Stretch="UniformToFill"/>
                                            </Border>
                                            
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                                <TextBlock Text="{Binding FullName}" FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>
                                                <StackPanel Orientation="Horizontal" Spacing="15">
                                                    <TextBlock Text="{Binding Phone}" FontSize="13" Foreground="#7F8C8D"/>
                                                    <TextBlock Text="{Binding Email}" FontSize="13" Foreground="#7F8C8D"/>
                                                </StackPanel>
                                            </StackPanel>
                                            
                                            <Border Grid.Column="2" Background="#EAFaf1" CornerRadius="6" Padding="10,5" VerticalAlignment="Center" IsVisible="{Binding IsSubscription}">
                                                <TextBlock Text="ПО АБОНЕМЕНТУ" FontSize="11" FontWeight="Bold" Foreground="#27AE60"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <StackPanel x:Name="NoClientsPanel" IsVisible="False" Margin="0,40,0,0" Spacing="10">
                            <TextBlock Text="👥" FontSize="40" HorizontalAlignment="Center"/>
                            <TextBlock Text="На эту тренировку пока никто не записался" FontSize="15" Foreground="#95A5A6" FontStyle="Italic" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>