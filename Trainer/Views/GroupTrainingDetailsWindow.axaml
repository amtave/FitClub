<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:FitClub.Models;assembly=FitClub"
        x:Class="FitClub.Trainer.Views.GroupTrainingDetailsWindow"
        Title="Детали групповой тренировки"
        Width="900"
        Height="600"
        MinWidth="700"
        MinHeight="400">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                  Text="{Binding #TrainingName.Text, Mode=OneWay}"
                  FontSize="20"
                  FontWeight="Bold"
                  Foreground="#2C3E50"
                  Margin="0,0,0,10"
                  Name="TrainingName"/>

        <!-- Информация о тренировке -->
        <Border Grid.Row="1"
                Background="#F8F9FA"
                BorderBrush="#BDC3C7"
                BorderThickness="1"
                CornerRadius="8"
                Padding="15"
                Margin="0,0,0,15">
            <Grid ColumnDefinitions="*,*,*,*">
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Дата и время"
                              FontSize="12"
                              FontWeight="SemiBold"
                              Foreground="#7F8C8D"/>
                    <TextBlock Name="DateAndTime"
                              FontSize="14"
                              FontWeight="Bold"
                              Foreground="#2C3E50"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Продолжительность"
                              FontSize="12"
                              FontWeight="SemiBold"
                              Foreground="#7F8C8D"/>
                    <TextBlock Name="Duration"
                              FontSize="14"
                              FontWeight="Bold"
                              Foreground="#2C3E50"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Участники"
                              FontSize="12"
                              FontWeight="SemiBold"
                              Foreground="#7F8C8D"/>
                    <TextBlock Name="ParticipantsInfo"
                              FontSize="14"
                              FontWeight="Bold"
                              Foreground="#27AE60"/>
                </StackPanel>

                <StackPanel Grid.Column="3">
                    <TextBlock Text="Интенсивность"
                              FontSize="12"
                              FontWeight="SemiBold"
                              Foreground="#7F8C8D"/>
                    <TextBlock Name="IntensityLevel"
                              FontSize="14"
                              FontWeight="Bold"
                              Foreground="#E74C3C"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Список участников -->
        <Border Grid.Row="2"
                BorderBrush="#BDC3C7"
                BorderThickness="1"
                CornerRadius="8"
                Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Заголовок списка -->
                <Border Grid.Row="0"
                        Background="#3498DB"
                        CornerRadius="8,8,0,0"
                        Padding="15,10">
                    <TextBlock Text="Записанные клиенты"
                              FontSize="16"
                              FontWeight="Bold"
                              Foreground="White"/>
                </Border>

                <!-- Список клиентов -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl Name="ParticipantsItemsControl" Padding="10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:TrainingBooking">
                                <Border Background="#F8F9FA" 
                                       CornerRadius="6" 
                                       Padding="15" 
                                       Margin="0,5"
                                       BorderBrush="#BDC3C7"
                                       BorderThickness="1">
                                    <!-- Увеличиваем ширину колонок: 200 для ФИО, * для email, 80 для фото -->
                                    <Grid ColumnDefinitions="200,*,80">
                                        <!-- ФИО клиента -->
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,15,0">
                                            <!-- ФИО в одну строку с переносом -->
                                            <TextBlock FontSize="13"
                                                      FontWeight="SemiBold"
                                                      Foreground="#2C3E50">
                                                <Run Text="{Binding Client.LastName}"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding Client.FirstName}"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding Client.MiddleName}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Client.Phone}"
                                                      FontSize="11"
                                                      Foreground="#7F8C8D"
                                                      Margin="0,2,0,0"/>
                                        </StackPanel>
                                        
                                        <!-- Email -->
                                        <TextBlock Grid.Column="1" 
                                                  Text="{Binding Client.Email}"
                                                  FontSize="12"
                                                  Foreground="#7F8C8D"
                                                  VerticalAlignment="Center"
                                                  TextWrapping="Wrap"
                                                  Margin="0,0,15,0"/>
                                        
                                        <!-- Фото клиента -->
                                        <Border Grid.Column="2" 
                                               Width="60" 
                                               Height="60" 
                                               CornerRadius="4"
                                               Background="#E8F6F3" 
                                               BorderBrush="#3498DB" 
                                               BorderThickness="1"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center">
                                            <Image Source="{Binding Client.AvatarBitmap}" 
                                                   Width="56" 
                                                   Height="56" 
                                                   Stretch="UniformToFill"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Сообщение если нет участников -->
                <TextBlock Grid.Row="1"
                          Name="NoParticipantsMessage"
                          Text="На эту тренировку пока никто не записался"
                          FontSize="14"
                          Foreground="#7F8C8D"
                          FontStyle="Italic"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          IsVisible="False"/>
            </Grid>
        </Border>

        <!-- Кнопка закрытия -->
        <Button Grid.Row="3"
                Content="Закрыть"
                Background="#95A5A6"
                Foreground="White"
                FontSize="14"
                FontWeight="SemiBold"
                Padding="20,10"
                HorizontalAlignment="Right"
                Click="CloseButton_Click"/>
    </Grid>
</Window>