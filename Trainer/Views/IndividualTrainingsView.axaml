<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:FitClub.Models;assembly=FitClub"
             xmlns:local="clr-namespace:FitClub.Trainer.Views;assembly=FitClub"
             x:Class="FitClub.Trainer.Views.IndividualTrainingsView">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" Spacing="20">
            <TextBlock Text="Индивидуальные занятия" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="#2C3E50"/>
            
            <!-- Информация о тренере -->
            <Border Background="#E8F6F3" CornerRadius="8" Padding="15">
                <StackPanel>
                    <TextBlock Name="TrainerInfoText"
                              FontSize="14" 
                              FontWeight="SemiBold"
                              Foreground="#2C3E50"
                              Text="Загрузка информации о тренере..."/>
                </StackPanel>
            </Border>

            <!-- Календарь -->
            <Border BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="8" Padding="15">
                <StackPanel Spacing="15">
                    <!-- НАВИГАЦИЯ ПО МЕСЯЦАМ -->
                    <Grid ColumnDefinitions="*,Auto,*">
                        <Button Grid.Column="0" 
                                Content="◀ Предыдущий" 
                                HorizontalAlignment="Left"
                                Click="PreviousMonth_Click"/>
                        
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                            <Button Content="Текущий месяц" 
                                    Click="CurrentMonth_Click"/>
                        </StackPanel>
                        
                        <Button Grid.Column="2" 
                                Content="Следующий ▶" 
                                HorizontalAlignment="Right"
                                Click="NextMonth_Click"/>
                    </Grid>
                    
                    <TextBlock Text="Календарь занятий" 
                              FontSize="16" 
                              FontWeight="Bold"
                              Foreground="#2C3E50"/>
                    
                    <!-- Легенда -->
                    <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <Border Width="15" Height="15" Background="#46C471" CornerRadius="3"/>
                            <TextBlock Text="Свободный день" FontSize="10"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <Border Width="15" Height="15" Background="#3498DB" CornerRadius="3"/>
                            <TextBlock Text="Есть занятия" FontSize="10"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <Border Width="15" Height="15" Background="#F39C12" CornerRadius="3"/>
                            <TextBlock Text="Выбрано" FontSize="10"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <Border Width="15" Height="15" Background="#95A5A6" CornerRadius="3"/>
                            <TextBlock Text="Не рабочий" FontSize="10"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- Дни недели -->
                    <Grid ColumnDefinitions="70,70,70,70,70,70,70" Margin="0,10,0,0">
                        <TextBlock Grid.Column="0" Text="Пн" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" Text="Вт" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Grid.Column="2" Text="Ср" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Grid.Column="3" Text="Чт" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Grid.Column="4" Text="Пт" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Grid.Column="5" Text="Сб" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Grid.Column="6" Text="Вс" HorizontalAlignment="Center" FontWeight="Bold"/>
                    </Grid>

                    <!-- Сетка календаря -->
                    <Grid x:Name="CalendarGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="70"/>
                            <RowDefinition Height="70"/>
                            <RowDefinition Height="70"/>
                            <RowDefinition Height="70"/>
                            <RowDefinition Height="70"/>
                            <RowDefinition Height="70"/>
                        </Grid.RowDefinitions>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Выбранная дата и слоты -->
<Border BorderBrush="#3498DB" BorderThickness="2" CornerRadius="8" Padding="15"
       Name="SelectedDateBorder" IsVisible="False">
    <StackPanel Spacing="10">
        <TextBlock Name="SelectedDateText"
                  FontSize="16" 
                  FontWeight="Bold"
                  Foreground="#2C3E50"/>
        
        <!-- ItemsControl для отображения тренировок -->
        <ItemsControl Name="TimeSlotsItemsControl">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="local:TrainingViewModel">
                    <Border Background="#F8F9FA" 
                           CornerRadius="8" 
                           Padding="15" 
                           Margin="0,5"
                           BorderBrush="#BDC3C7"
                           BorderThickness="1">
                        <Grid ColumnDefinitions="120,*,150">
                            <!-- Время тренировки -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="{Binding TimeRangeFormatted}"
                                          FontSize="14"
                                          FontWeight="Bold"
                                          Foreground="#2C3E50"
                                          TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding DurationFormatted}"
                                          FontSize="11"
                                          Foreground="#7F8C8D"
                                          FontStyle="Italic"
                                          Margin="0,2,0,0"/>
                            </StackPanel>
                            
                            <!-- Информация о клиенте -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="{Binding ClientFullName}"
                                          FontSize="13"
                                          FontWeight="SemiBold"
                                          Foreground="#2C3E50"/>
                                <TextBlock Text="{Binding ClientPhone}"
                                          FontSize="12"
                                          Foreground="#7F8C8D"
                                          Margin="0,2,0,0"/>
                                <TextBlock Text="Индивидуальная тренировка"
                                          FontSize="11"
                                          Foreground="#3498DB"
                                          FontWeight="SemiBold"
                                          Margin="0,4,0,0"/>
                            </StackPanel>
                            
                            <!-- Фото клиента -->
                            <Border Grid.Column="2" 
                                   Width="60" 
                                   Height="60" 
                                   CornerRadius="4"
                                   Background="#E8F6F3" 
                                   BorderBrush="#3498DB" 
                                   BorderThickness="1"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                                <Image Source="{Binding ClientAvatar}" 
                                       Width="56" 
                                       Height="56" 
                                       Stretch="UniformToFill"/>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Сообщение если нет слотов -->
        <TextBlock Name="NoSlotsMessage"
                  Text="На выбранную дату нет индивидуальных занятий"
                  FontSize="12"
                  Foreground="#7F8C8D"
                  FontStyle="Italic"
                  HorizontalAlignment="Center"
                  IsVisible="False"/>
    </StackPanel>
</Border>

            <!-- Сообщение если дата не выбрана -->
            <Border Background="#FFF9E6" CornerRadius="8" Padding="15"
                   Name="NoDateSelectedBorder">
                <TextBlock Text="Выберите дату в календаре для просмотра индивидуальных занятий"
                          FontSize="12"
                          Foreground="#E67E22"
                          HorizontalAlignment="Center"/>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>