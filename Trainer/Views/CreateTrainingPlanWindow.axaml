<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:FitClub.Models;assembly=FitClub"
        xmlns:local="clr-namespace:FitClub.Trainer.Views;assembly=FitClub"
        x:Class="FitClub.Trainer.Views.CreateTrainingPlanWindow"
        Title="План тренировок"
        Width="850" Height="700"
        WindowStartupLocation="CenterOwner"
        Background="#F4F7F9">

    <Window.Styles>
        <Style Selector="DataValidationErrors">
            <Setter Property="ErrorTemplate">
                <DataTemplate>
                    <Border Width="16" Height="16" CornerRadius="8" Background="#E74C3C" Margin="4,0,0,0" ToolTip.Tip="Обязательно для заполнения (только числа)">
                        <TextBlock Text="!" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </DataTemplate>
            </Setter>
        </Style>
    </Window.Styles>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30" Spacing="20">
            
            <StackPanel Margin="0,0,0,10">
                <TextBlock x:Name="WindowTitleText" Text="📝 ПЛАН ТРЕНИРОВОК" FontSize="26" FontWeight="ExtraBold" Foreground="#2C3E50" LetterSpacing="1"/>
                <Border Height="4" Width="70" Background="#FF8955" HorizontalAlignment="Left" Margin="0,8,0,0" CornerRadius="2"/>
            </StackPanel>

            <Border Background="White" CornerRadius="12" Padding="25" BorderBrush="#E0E6ED" BorderThickness="1" BoxShadow="0 4 15 0 #05000000">
                <StackPanel Spacing="20">
                    <Border Background="#F8F9FA" CornerRadius="8" Padding="15" BorderBrush="#E0E6ED" BorderThickness="1">
                        <Grid ColumnDefinitions="Auto, *">
                            <TextBlock Text="👤 Клиент:" FontSize="15" FontWeight="SemiBold" Foreground="#7F8C8D" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock x:Name="ClientInfoText" Grid.Column="1" FontSize="17" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Grid ColumnDefinitions="120, *" RowDefinitions="Auto, Auto" RowSpacing="15">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Цель плана:" FontSize="15" FontWeight="SemiBold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="GoalsComboBox" HorizontalAlignment="Stretch" CornerRadius="8" Background="#FDFEFE" BorderBrush="#E0E6ED">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="models:TrainingPlanGoal">
                                    <StackPanel Margin="5">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#2C3E50" FontSize="14"/>
                                        <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#7F8C8D" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Примечания:" FontSize="15" FontWeight="SemiBold" Foreground="#2C3E50" VerticalAlignment="Top" Margin="0,10,0,0"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="NotesTextBox" Watermark="Дополнительные примечания к плану..." Height="60" TextWrapping="Wrap" CornerRadius="8" Background="#FDFEFE" BorderBrush="#E0E6ED"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="12" Padding="25" BorderBrush="#E0E6ED" BorderThickness="1" BoxShadow="0 4 15 0 #05000000">
                <StackPanel Spacing="15">
                    <StackPanel Spacing="5" Margin="0,0,0,10">
                        <TextBlock Text="Программа на 12 дней" FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>
                        <TextBlock Text="Заполните необходимые упражнения для тренировочных дней" FontSize="13" Foreground="#7F8C8D"/>
                    </StackPanel>
                    
                    <ItemsControl x:Name="TrainingDaysList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:ObservableDay">
                                <Border Background="#FDFEFE" CornerRadius="10" Padding="20" Margin="0,0,0,15" BorderBrush="#E0E6ED" BorderThickness="1">
                                    <StackPanel Spacing="15">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <Border Background="#EAF2F8" CornerRadius="6" Padding="12,6" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding DayNumber, StringFormat='День {0}'}" FontWeight="Bold" Foreground="#3498DB" FontSize="14"/>
                                            </Border>
                                            
                                            <Button Grid.Column="1" Content="+ Добавить" Background="#EAFaf1" Foreground="#27AE60" FontSize="12" FontWeight="Bold" CornerRadius="6" Padding="12,6" Cursor="Hand" Click="OnAddExerciseClick" Tag="{Binding}"/>
                                        </Grid>
                                        
                                        <ItemsControl ItemsSource="{Binding Exercises}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="models:Exercise">
                                                    <Border Background="#F8F9FA" CornerRadius="8" Padding="12" Margin="0,8,0,0" BorderBrush="#EBEDF0" BorderThickness="1">
                                                        <Grid ColumnDefinitions="*, 65, 65, 75, 75, Auto" ColumnSpacing="8">
                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                                <TextBlock Text="Упражнение" FontSize="10" FontWeight="SemiBold" Foreground="#95A5A6" Margin="0,0,0,4"/>
                                                                <TextBox Text="{Binding Name, Mode=TwoWay}" Watermark="Название" FontSize="12" CornerRadius="6" Padding="8,5" Background="White" BorderBrush="#E0E6ED"/>
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                <TextBlock Text="Подходы" FontSize="10" FontWeight="SemiBold" Foreground="#95A5A6" Margin="0,0,0,4"/>
                                                                <TextBox Text="{Binding Sets, Mode=TwoWay}" Watermark="3" FontSize="12" CornerRadius="6" Padding="8,5" Background="White" BorderBrush="#E0E6ED" TextAlignment="Center"/>
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                                <TextBlock Text="Повторы" FontSize="10" FontWeight="SemiBold" Foreground="#95A5A6" Margin="0,0,0,4"/>
                                                                <TextBox Text="{Binding Reps, Mode=TwoWay}" Watermark="12" FontSize="12" CornerRadius="6" Padding="8,5" Background="White" BorderBrush="#E0E6ED" TextAlignment="Center"/>
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                                                <TextBlock Text="Время (м)" FontSize="10" FontWeight="SemiBold" Foreground="#95A5A6" Margin="0,0,0,4"/>
                                                                <TextBox Text="{Binding Duration, Mode=TwoWay}" Watermark="45" FontSize="12" CornerRadius="6" Padding="8,5" Background="White" BorderBrush="#E0E6ED" TextAlignment="Center"/>
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                                                <TextBlock Text="Отдых (с)" FontSize="10" FontWeight="SemiBold" Foreground="#95A5A6" Margin="0,0,0,4"/>
                                                                <TextBox Text="{Binding Rest, Mode=TwoWay}" Watermark="60" FontSize="12" CornerRadius="6" Padding="8,5" Background="White" BorderBrush="#E0E6ED" TextAlignment="Center"/>
                                                            </StackPanel>
                                                            
                                                            <Button Grid.Column="5" Content="✕" Background="#FDEDEC" Foreground="#E74C3C" FontSize="12" FontWeight="Bold" CornerRadius="6" Width="28" Height="28" Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Cursor="Hand" VerticalAlignment="Bottom" Click="OnRemoveExerciseClick" Tag="{Binding}"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Grid ColumnDefinitions="*, *" Margin="0,10,0,20">
                <Button Grid.Column="0" Content="Отмена" Background="#F8F9FA" Foreground="#7F8C8D" BorderBrush="#BDC3C7" BorderThickness="1" FontSize="14" FontWeight="Bold" CornerRadius="8" Padding="0,12" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Cursor="Hand" Margin="0,0,10,0" Click="OnCancelClick"/>
                <Button Grid.Column="1" Content="Сохранить план" Background="#27AE60" Foreground="White" FontSize="14" FontWeight="Bold" CornerRadius="8" Padding="0,12" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Cursor="Hand" Margin="10,0,0,0" Click="OnSavePlanClick"/>
            </Grid>

            <Border x:Name="StatusMessage" CornerRadius="8" Padding="15" IsVisible="False" Margin="0,0,0,20">
                <TextBlock x:Name="StatusText" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
            </Border>
            
        </StackPanel>
    </ScrollViewer>
</Window>