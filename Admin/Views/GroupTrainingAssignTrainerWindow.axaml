<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FitClub.Admin.Views;assembly=FitClub"
        x:Class="FitClub.Admin.Views.GroupTrainingAssignTrainerWindow"
        Title="Назначение тренеров" Width="550" Height="650"
        WindowStartupLocation="CenterOwner" CanResize="False">
    <Grid RowDefinitions="Auto, Auto, *, Auto" Margin="20">
        <TextBlock Grid.Row="0" Text="Назначить тренеров" FontSize="20" FontWeight="Bold" Margin="0,0,0,15" Foreground="#2C3E50"/>
        
        <Grid Grid.Row="1" ColumnDefinitions="*, Auto" Margin="0,0,0,15">
            <TextBox x:Name="SearchTextBox" Grid.Column="0" Watermark="🔍 Поиск по ФИО..." Margin="0,0,10,0" KeyUp="SearchTextBox_KeyUp"/>
            <ComboBox x:Name="SpecComboBox" Grid.Column="1" Width="200" SelectionChanged="SpecComboBox_SelectionChanged">
                <ComboBoxItem Content="Все специализации"/>
                <ComboBoxItem Content="Кардио"/>
                <ComboBoxItem Content="Силовая"/>
                <ComboBoxItem Content="Йога"/>
                <ComboBoxItem Content="Функциональная"/>
                <ComboBoxItem Content="Танцевальная"/>
                <ComboBoxItem Content="Единоборства"/>
            </ComboBox>
        </Grid>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="TrainersItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="local:TrainerSelectionItem">
                        <Border Background="White" CornerRadius="10" Padding="15" Margin="0,0,5,10" BorderBrush="{Binding BorderColor}" BorderThickness="2">
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <Border Grid.Column="0" Width="60" Height="60" CornerRadius="30" ClipToBounds="True" BorderBrush="#3498DB" BorderThickness="1" Margin="0,0,15,0">
                                    <Image Source="{Binding Trainer.PhotoBitmap}" Stretch="UniformToFill"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                    <TextBlock Text="{Binding Trainer.FullName}" FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>
                                    <TextBlock Text="{Binding Trainer.Specialization}" FontSize="12" Foreground="#3498DB" FontStyle="Italic" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Trainer.ExperienceInfo}" FontSize="12" Foreground="#7F8C8D" TextWrapping="Wrap"/>
                                </StackPanel>
                                <CheckBox Grid.Column="2" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <CheckBox.Styles>
                                        <Style Selector="CheckBox">
                                            <Setter Property="RenderTransform" Value="scale(1.3)"/>
                                        </Style>
                                    </CheckBox.Styles>
                                </CheckBox>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,15,0,0">
            <Button Content="Отмена" Click="Cancel_Click" Width="80"/>
            <Button Content="Сохранить" Click="Save_Click" Width="100" Background="#27AE60" Foreground="White" HorizontalContentAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>