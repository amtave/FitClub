<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:FitClub.Models;assembly=FitClub"
        x:Class="FitClub.Admin.Views.AddGroupTrainingSlotWindow"
        Title="Добавить групповую тренировку" Width="350" Height="450"
        WindowStartupLocation="CenterOwner" CanResize="False">
    <Grid RowDefinitions="Auto, Auto, Auto, *, Auto" Margin="20">
        <TextBlock Grid.Row="0" Text="Добавление групповой" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
        
        <TextBlock Grid.Row="1" Text="Выберите тренировку:" Margin="0,0,0,5"/>
        <ComboBox Grid.Row="2" x:Name="TrainingComboBox" Width="310" Height="40" Margin="0,0,0,15">
            <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="models:GroupTraining">
                    <TextBlock Text="{Binding Name}"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock Grid.Row="3" Text="Доступное время:" Margin="0,0,0,5" VerticalAlignment="Top"/>
        <ScrollViewer Grid.Row="3" Margin="0,25,0,0">
            <StackPanel x:Name="TimeRadioStack" Spacing="5">
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Отмена" Click="Cancel_Click" Width="80"/>
            <Button Content="Добавить" Click="Ok_Click" Width="90" Background="#3498DB" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>