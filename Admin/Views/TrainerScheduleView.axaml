<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:FitClub.Models;assembly=FitClub"
             xmlns:local="clr-namespace:FitClub.Admin.Views;assembly=FitClub"
             x:Class="FitClub.Admin.Views.TrainerScheduleView">
    
    <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto, *" Margin="20">
        
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Управление расписанием тренеров" FontSize="26" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Grid.Column="0" Width="360" Spacing="8" Margin="0,0,20,15" VerticalAlignment="Bottom">
            <TextBlock Text="Выберите тренера:" FontSize="16" Foreground="#34495E" FontWeight="SemiBold"/>
            <ComboBox x:Name="TrainerComboBox" Width="360" Height="40" SelectionChanged="TrainerChanged">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="models:Trainer">
                        <TextBlock Text="{Binding FullName}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Content="Сгенерировать для всех" Click="GenerateMonth_Click" Width="360" HorizontalContentAlignment="Center" Background="#27AE60" Foreground="White" CornerRadius="5" Padding="10" FontSize="14" FontWeight="Bold" Margin="0,5,0,0"/>
        </StackPanel>

        <Border Grid.Row="2" Grid.Column="0" Width="360" Background="White" CornerRadius="10" BorderBrush="#E0E0E0" BorderThickness="1" Padding="15" Margin="0,0,20,0" VerticalAlignment="Top">
            <StackPanel Spacing="10">
                <Grid ColumnDefinitions="Auto, *, Auto">
                    <Button Grid.Column="0" Content="◀" Background="Transparent" Click="PrevMonth_Click" FontSize="18" Cursor="Hand"/>
                    <TextBlock x:Name="MonthYearText" Grid.Column="1" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Content="▶" Background="Transparent" Click="NextMonth_Click" FontSize="18" Cursor="Hand"/>
                </Grid>
                <UniformGrid Columns="7" Margin="0,10">
                    <TextBlock Text="Пн" HorizontalAlignment="Center" FontSize="14" Foreground="#7F8C8D"/>
                    <TextBlock Text="Вт" HorizontalAlignment="Center" FontSize="14" Foreground="#7F8C8D"/>
                    <TextBlock Text="Ср" HorizontalAlignment="Center" FontSize="14" Foreground="#7F8C8D"/>
                    <TextBlock Text="Чт" HorizontalAlignment="Center" FontSize="14" Foreground="#7F8C8D"/>
                    <TextBlock Text="Пт" HorizontalAlignment="Center" FontSize="14" Foreground="#7F8C8D"/>
                    <TextBlock Text="Сб" HorizontalAlignment="Center" FontSize="14" Foreground="#E74C3C"/>
                    <TextBlock Text="Вс" HorizontalAlignment="Center" FontSize="14" Foreground="#E74C3C"/>
                </UniformGrid>
                <ItemsControl x:Name="CalendarItemsControl">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="7"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:ExtendedCalendarDay">
                            <Button Classes="CalendarDayBtn" Click="CalendarDay_Click" IsEnabled="{Binding IsEnabled}" Width="42" Height="42" Margin="2" CornerRadius="21"
                                    BorderBrush="{Binding BorderColor}" BorderThickness="{Binding BorderThickness}">
                                <Button.Styles>
                                    <Style Selector="Button.CalendarDayBtn">
                                        <Setter Property="Background" Value="#F2F4F4"/>
                                        <Setter Property="Foreground" Value="#2C3E50"/>
                                    </Style>
                                    <Style Selector="Button.CalendarDayBtn[IsDefault=True]">
                                        <Setter Property="Background" Value="#3498DB"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </Button.Styles>
                                <Button.IsDefault><Binding Path="IsSelected"/></Button.IsDefault>
                                <TextBlock Text="{Binding Day}"/>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Background="#F8F9FA" CornerRadius="8" Padding="15" Margin="0,15,0,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Легенда цветовой индикации:" FontSize="12" FontWeight="Bold" Foreground="#7F8C8D" Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Width="12" Height="12" CornerRadius="6" Background="White" BorderBrush="#2ECC71" BorderThickness="2"/>
                            <TextBlock Text="Есть тренировки по графику" FontSize="11" Foreground="#2C3E50" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Width="12" Height="12" CornerRadius="6" Background="White" BorderBrush="#8E44AD" BorderThickness="2"/>
                            <TextBlock Text="Тренировки в законный ВЫХОДНОЙ" FontSize="11" Foreground="#2C3E50" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Width="12" Height="12" CornerRadius="6" Background="White" BorderBrush="#F39C12" BorderThickness="2"/>
                            <TextBlock Text="Уважительная причина (Больничный/Отгул)" FontSize="11" Foreground="#2C3E50" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Width="12" Height="12" CornerRadius="6" Background="White" BorderBrush="#E74C3C" BorderThickness="2"/>
                            <TextBlock Text="НЕУВАЖИТЕЛЬНАЯ причина (Прогул)" FontSize="11" Foreground="#2C3E50" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Background="#F8F9FA" CornerRadius="12" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,15" HorizontalAlignment="Stretch">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" DataContext="{Binding #TrainerComboBox.SelectedItem}" x:DataType="models:Trainer">
                    <Border Width="60" Height="60" CornerRadius="30" ClipToBounds="True" Margin="0,0,15,0" BorderBrush="#3498DB" BorderThickness="2">
                        <Image Source="{Binding PhotoBitmap}" Stretch="UniformToFill"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="{Binding FullName}" FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>
                        <TextBlock Text="{Binding WorkScheduleDescription}" FontSize="12" Foreground="#2980B9" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <ComboBox x:Name="ReportMonthPicker" Width="140" SelectedIndex="0">
                        <ComboBoxItem Content="Январь"/>
                        <ComboBoxItem Content="Февраль"/>
                        <ComboBoxItem Content="Март"/>
                        <ComboBoxItem Content="Апрель"/>
                        <ComboBoxItem Content="Май"/>
                        <ComboBoxItem Content="Июнь"/>
                        <ComboBoxItem Content="Июль"/>
                        <ComboBoxItem Content="Август"/>
                        <ComboBoxItem Content="Сентябрь"/>
                        <ComboBoxItem Content="Октябрь"/>
                        <ComboBoxItem Content="Ноябрь"/>
                        <ComboBoxItem Content="Декабрь"/>
                    </ComboBox>
                    <Button Content="📊 Выписка по графику" Click="ExportTrainerReport_Click" Background="#3498DB" Foreground="White" Padding="15,8" FontWeight="Bold" CornerRadius="6"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Grid.Column="1" Background="White" CornerRadius="10" BorderBrush="#E0E0E0" BorderThickness="1" Padding="20">
            <Grid RowDefinitions="Auto, *">
                <Grid Grid.Row="0" ColumnDefinitions="Auto, *" Margin="0,0,0,15">
                    <TextBlock x:Name="SelectedDateText" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" x:Name="ActionButtonsPanel" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" IsVisible="False">
                        <Button x:Name="AddGroupBtn" Content="➕ Групповая" Click="AddGroupTraining_Click" Background="#3498DB" Foreground="White" CornerRadius="5" Padding="10,6" FontSize="12"/>
                        <Button x:Name="AddIndBtn" Content="➕ Индив. слоты" Click="OpenAddSlots_Click" Background="#9B59B6" Foreground="White" CornerRadius="5" Padding="10,6" FontSize="12"/>
                        <Button x:Name="DuplicateDayButton" Content="📋 Дублировать" Click="DuplicateDay_Click" Background="#F39C12" Foreground="White" CornerRadius="5" Padding="10,6" FontSize="12"/>
                        <Button x:Name="ClearDayButton" Content="🗑 Очистить день (Пропуск)" Click="ClearDayClick" Background="#E74C3C" Foreground="White" CornerRadius="5" Padding="10,6" FontSize="12"/>
                    </StackPanel>
                </Grid>
                <ScrollViewer Grid.Row="1">
                    <StackPanel>
                        <Border x:Name="AbsenceInfoBorder" Background="#FFF3E0" BorderBrush="#F39C12" BorderThickness="2" CornerRadius="8" Padding="20" Margin="0,0,0,15" IsVisible="False">
                            <StackPanel Spacing="15">
                                <StackPanel Spacing="5">
                                    <TextBlock x:Name="AbsenceTitleText" FontSize="18" FontWeight="Bold" Foreground="#E67E22"/>
                                    <TextBlock x:Name="AbsenceDateRangeText" FontSize="14" FontWeight="SemiBold" Foreground="#2C3E50" IsVisible="False"/>
                                    <TextBlock x:Name="AbsenceCommentText" FontSize="14" Foreground="#2C3E50" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Border x:Name="AbsencePhotoBorder" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" ClipToBounds="True" Height="400" MaxWidth="600" HorizontalAlignment="Left" Background="White" IsVisible="False">
                                    <Image x:Name="AbsencePhotoPreview" Stretch="Uniform"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <ItemsControl x:Name="ScheduleItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:ScheduleItemViewModel">
                                    <Border Background="{Binding BackgroundBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,10" BorderBrush="{Binding BorderBrush}" BorderThickness="4,1,1,1">
                                        <Grid ColumnDefinitions="140, *, Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding TimeRangeFormatted}" FontSize="17" FontWeight="Bold" Foreground="{Binding BorderBrush}" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0">
                                                <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>
                                                <TextBlock Text="{Binding Subtitle}" FontSize="13" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <Button Grid.Column="2" Content="Удалить" Background="#E74C3C" Foreground="White" CornerRadius="5" Padding="12,6" Click="DeleteSessionClick" Tag="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock x:Name="NoSchedulesText" Text="Записей не найдено" FontSize="15" Foreground="#95A5A6" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,40,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>