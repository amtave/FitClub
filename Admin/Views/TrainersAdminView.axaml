<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:FitClub.Models;assembly=FitClub"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="600"
             x:Class="FitClub.Admin.Views.TrainersAdminView">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" Spacing="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" 
                           Text="👥 Управление тренерами" 
                           FontSize="28" FontWeight="Bold" 
                           Foreground="#2C3E50"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="📄 Заявки на работу"
                        Background="#FF8955"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="20,10"
                        CornerRadius="5"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="OpenJobApplications_Click"/>
            </Grid>

            <Border Height="2" Background="#FF8955" HorizontalAlignment="Stretch"/>

            <Grid ColumnDefinitions="*,Auto">
                <TextBox x:Name="SearchTextBox" 
                         Grid.Column="0"
                         Watermark="🔍 Поиск тренера по ФИО..."
                         Margin="0,0,15,0"
                         KeyUp="SearchTextBox_KeyUp"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="15">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Специализация:" VerticalAlignment="Center" Foreground="#7F8C8D"/>
                        <ComboBox x:Name="SpecFilterComboBox" Width="140" SelectionChanged="FilterComboBox_SelectionChanged">
                            <ComboBoxItem Content="Все"/>
                            <ComboBoxItem Content="Кардио"/>
                            <ComboBoxItem Content="Силовой тренинг"/>
                            <ComboBoxItem Content="Йога"/>
                            <ComboBoxItem Content="Функциональный"/>
                            <ComboBoxItem Content="Танцевальная"/>
                            <ComboBoxItem Content="Единоборства"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Направления:" VerticalAlignment="Center" Foreground="#7F8C8D"/>
                        <ComboBox x:Name="GroupFilterComboBox" Width="140" SelectionChanged="FilterComboBox_SelectionChanged"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="График:" VerticalAlignment="Center" Foreground="#7F8C8D"/>
                        <ComboBox x:Name="ScheduleFilterComboBox" Width="110" SelectionChanged="FilterComboBox_SelectionChanged">
                            <ComboBoxItem Content="Все"/>
                            <ComboBoxItem Content="Пн-Пт"/>
                            <ComboBoxItem Content="Ср-Вс"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Grid>
            
            <Border x:Name="NoTrainersBorder"
                    Background="#F8F9FA" 
                    CornerRadius="10" 
                    Padding="40"
                    IsVisible="False">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                    <TextBlock Text="👥" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="Тренеры не найдены" FontSize="18" Foreground="#7F8C8D" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            
            <ItemsControl x:Name="TrainersItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:Trainer">
                        <Border Background="White" CornerRadius="10" Padding="20" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,15">
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <Border Grid.Column="0" Width="120" Height="140" CornerRadius="8" BorderBrush="#3498DB" BorderThickness="1" Margin="0,0,20,0" ClipToBounds="True">
                                    <Image Source="{Binding PhotoBitmap}" Stretch="UniformToFill"/>
                                </Border>
                                
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="8">
                                    <TextBlock Text="{Binding FullName}" FontSize="20" FontWeight="Bold" Foreground="#2C3E50"/>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Border Background="{Binding StatusColor}" CornerRadius="5" Padding="5,2">
                                            <TextBlock Text="{Binding StatusText}" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                        </Border>
                                        <Border Background="#EBF5FB" CornerRadius="5" Padding="5,2">
                                            <TextBlock Text="{Binding ExperienceInfo}" FontSize="12" FontWeight="SemiBold" Foreground="#3498DB"/>
                                        </Border>
                                        <Border Background="#FDF2ED" CornerRadius="5" Padding="5,2">
                                            <TextBlock Text="{Binding WorkScheduleDescription}" FontSize="12" FontWeight="SemiBold" Foreground="#D35400"/>
                                        </Border>
                                    </StackPanel>
                                    
                                    <TextBlock Text="{Binding Specialization}" FontSize="14" FontWeight="SemiBold" Foreground="#27AE60" TextWrapping="Wrap"/>
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,5,0,0">
                                        <TextBlock Text="🎯 Ведет:" FontSize="13" Foreground="#7F8C8D" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding GroupTrainingsList}" FontSize="13" Foreground="#34495E" FontStyle="Italic" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="15" Margin="0,5,0,0">
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <TextBlock Text="📞" FontSize="14"/>
                                            <TextBlock Text="{Binding Phone}" FontSize="13" Foreground="#2C3E50"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <TextBlock Text="✉️" FontSize="14"/>
                                            <TextBlock Text="{Binding Email}" FontSize="13" Foreground="#2C3E50"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                                
                                <UniformGrid Grid.Column="2" Columns="2" Rows="2" Width="300" VerticalAlignment="Center">
                                    <Button Content="👤 Карточка" 
                                        Margin="5" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                        Background="#EBF5FB" Foreground="#2980B9" 
                                        BorderThickness="0" Padding="0,12" CornerRadius="6"
                                        FontSize="12" FontWeight="SemiBold" Cursor="Hand" 
                                        Click="OpenTrainerDetails_Click" Tag="{Binding}"/>
                                            
                                    <Button Content="📅 Расписание" 
                                            Margin="5" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Background="#F4ECF7" Foreground="#8E44AD" 
                                            BorderThickness="0" Padding="0,12" CornerRadius="6"
                                            FontSize="12" FontWeight="SemiBold" Cursor="Hand" 
                                            Click="OpenSchedule_Click" Tag="{Binding}"/>
                                            
                                    <Button Content="✏️ Редактировать" 
                                            Margin="5" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Background="#FEF5E7" Foreground="#D68910" 
                                            BorderThickness="0" Padding="0,12" CornerRadius="6"
                                            FontSize="12" FontWeight="SemiBold" Cursor="Hand" 
                                            Click="EditTrainer_Click" Tag="{Binding}"/>
                                            
                                    <Button Content="🚫 Уволить" 
                                            Margin="5" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Background="#FDEDEC" Foreground="#C0392B" 
                                            BorderThickness="0" Padding="0,12" CornerRadius="6"
                                            FontSize="12" FontWeight="SemiBold" Cursor="Hand" 
                                            Click="FireTrainer_Click" Tag="{Binding}"/>
                                </UniformGrid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>