<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FitClub.Admin.Views.ClientDetailsWindow"
        Title="Информация о клиенте" Width="800" Height="850"
        WindowStartupLocation="CenterOwner" CanResize="False"
        Background="#F4F7F9">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="10" Margin="0,0,0,20">
            <TextBlock x:Name="TitleText" FontSize="26" FontWeight="ExtraBold" Foreground="#2C3E50" HorizontalAlignment="Center" LetterSpacing="0.5"/>
            <Border x:Name="TitleBorder" Height="3" Width="80" HorizontalAlignment="Center" CornerRadius="2"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20" Margin="0,0,10,0">
                <Border Background="White" CornerRadius="12" Padding="20" BorderBrush="#E0E6ED" BorderThickness="1">
                    <StackPanel Spacing="15">
                        <TextBlock Text="СТАТУС ДОКУМЕНТОВ" FontSize="13" FontWeight="Bold" Foreground="#95A5A6" LetterSpacing="1"/>
                        <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto, Auto">
                            <Border Grid.Row="0" Grid.Column="0" x:Name="StatusBadge" CornerRadius="6" Padding="12,6" Margin="0,0,15,0">
                                <TextBlock x:Name="StatusText" FontSize="14" FontWeight="Bold" Foreground="White"/>
                            </Border>
                            
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
                                <StackPanel>
                                    <TextBlock Text="Отправлено:" FontSize="11" Foreground="#7F8C8D"/>
                                    <TextBlock x:Name="SubmittedAtText" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Проверено:" FontSize="11" Foreground="#7F8C8D"/>
                                    <TextBlock x:Name="ReviewedAtText" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <Border x:Name="RejectionReasonBorder" Background="#FDEDEC" CornerRadius="8" Padding="15" Margin="0,5,0,0" IsVisible="False">
                            <StackPanel Spacing="5">
                                <TextBlock Text="Причина отказа:" FontWeight="Bold" Foreground="#E74C3C" FontSize="13"/>
                                <TextBlock x:Name="RejectionReasonText" TextWrapping="Wrap" Foreground="#2C3E50"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" Padding="20" BorderBrush="#E0E6ED" BorderThickness="1">
                    <StackPanel Spacing="15">
                        <TextBlock Text="ЛИЧНЫЕ ДАННЫЕ" FontSize="13" FontWeight="Bold" Foreground="#95A5A6" LetterSpacing="1"/>
                        <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto">
                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="3" Margin="0,0,0,15">
                                <TextBlock Text="ФИО" FontSize="11" Foreground="#7F8C8D"/>
                                <TextBlock x:Name="FullNameText" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" TextWrapping="Wrap"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Row="1" Grid.Column="0" Spacing="3">
                                <TextBlock Text="Телефон" FontSize="11" Foreground="#7F8C8D"/>
                                <TextBlock x:Name="PhoneText" FontSize="15" FontWeight="SemiBold" Foreground="#2C3E50"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="3">
                                <TextBlock Text="Email" FontSize="11" Foreground="#7F8C8D"/>
                                <TextBlock x:Name="EmailText" FontSize="15" FontWeight="SemiBold" Foreground="#2C3E50" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" Padding="20" BorderBrush="#E0E6ED" BorderThickness="1">
                    <StackPanel Spacing="15">
                        <TextBlock Text="ДОКУМЕНТЫ" FontSize="13" FontWeight="Bold" Foreground="#95A5A6" LetterSpacing="1"/>
                        
                        <Grid ColumnDefinitions="*, *" Margin="0,0,0,10">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="Серия паспорта" FontSize="11" Foreground="#7F8C8D"/>
                                <TextBlock x:Name="PassportSeriesText" FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="3">
                                <TextBlock Text="Номер паспорта" FontSize="11" Foreground="#7F8C8D"/>
                                <TextBlock x:Name="PassportNumberText" FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>
                            </StackPanel>
                        </Grid>
                        
                        <Grid ColumnDefinitions="*, *">
                            <StackPanel Grid.Column="0" Spacing="8" Margin="0,0,10,0">
                                <Border Background="#F4F7F9" CornerRadius="6" Padding="8">
                                    <TextBlock Text="Разворот паспорта" FontSize="12" FontWeight="SemiBold" Foreground="#34495E" HorizontalAlignment="Center"/>
                                </Border>
                                <Border BorderBrush="#E0E6ED" BorderThickness="2" CornerRadius="8" Padding="5" Height="220" Background="#FAFAFA">
                                    <Image x:Name="PassportPhotoImage" Stretch="Uniform"/>
                                </Border>
                                <TextBlock x:Name="PhotoStatusText" FontSize="12" FontWeight="Medium" Foreground="#7F8C8D" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="8" Margin="10,0,0,0">
                                <Border Background="#F4F7F9" CornerRadius="6" Padding="8">
                                    <TextBlock Text="Бланк согласия" FontSize="12" FontWeight="SemiBold" Foreground="#34495E" HorizontalAlignment="Center"/>
                                </Border>
                                <Border BorderBrush="#E0E6ED" BorderThickness="2" CornerRadius="8" Padding="5" Height="220" Background="#FAFAFA">
                                    <Image x:Name="ConsentPhotoImage" Stretch="Uniform"/>
                                </Border>
                                <TextBlock x:Name="ConsentStatusText" FontSize="12" FontWeight="Medium" Foreground="#7F8C8D" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="Закрыть окно" Background="#BDC3C7" Foreground="White" Padding="40,12" FontSize="15" FontWeight="Bold" CornerRadius="8" Cursor="Hand" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>