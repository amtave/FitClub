<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:FitClub.Models;assembly=FitClub"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="850"
        x:Class="FitClub.Admin.Views.GroupTrainingAddWindow"
        Title="Добавление новой тренировки"
        Width="600" Height="850"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Border Padding="30">
            <StackPanel Spacing="18">
                <TextBlock Text="Новая групповая тренировка" 
                           FontSize="24" FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           Foreground="#2C3E50" 
                           Margin="0,0,0,15"/>

                <StackPanel Spacing="8" HorizontalAlignment="Center">
                    <Border Width="180" Height="180" CornerRadius="12" 
                            ClipToBounds="True" BorderBrush="#E0E0E0" BorderThickness="1"
                            Background="#F8F9FA">
                        <Image x:Name="PreviewImage" Stretch="UniformToFill"/>
                    </Border>
                    <Button Content="Выбрать фото" 
                            HorizontalAlignment="Center"
                            Background="#FF8955" Foreground="White"
                            Padding="15,5" CornerRadius="5"
                            Click="SelectImageButton_Click"/>
                </StackPanel>

                <StackPanel Spacing="5">
                    <TextBlock Text="Название тренировки" Foreground="#7F8C8D" FontWeight="SemiBold"/>
                    <TextBox x:Name="NameTextBox" Watermark="Введите название..."/>
                    <TextBlock x:Name="NameErrorText" Text="Поле должно быть заполнено" Foreground="Red" FontSize="11" IsVisible="False"/>
                </StackPanel>

                <StackPanel Spacing="5">
                    <TextBlock Text="Описание" Foreground="#7F8C8D" FontWeight="SemiBold"/>
                    <TextBox x:Name="DescriptionTextBox" Height="80" 
                             TextWrapping="Wrap" AcceptsReturn="True"
                             Watermark="Введите описание тренировки..."/>
                    <TextBlock x:Name="DescriptionErrorText" Text="Поле должно быть заполнено" Foreground="Red" FontSize="11" IsVisible="False"/>
                </StackPanel>

                <Grid ColumnDefinitions="*,*">
                    <StackPanel Grid.Column="0" Spacing="5" Margin="0,0,10,0">
                        <TextBlock Text="Уровень интенсивности" Foreground="#7F8C8D" FontWeight="SemiBold"/>
                        <ComboBox x:Name="IntensityComboBox" HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate DataType="models:IntensityLevel">
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="5" Margin="10,0,0,0">
                        <TextBlock Text="Тип тренировки" Foreground="#7F8C8D" FontWeight="SemiBold"/>
                        <ComboBox x:Name="TypeComboBox" HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate DataType="models:TrainingType">
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <Grid ColumnDefinitions="*,*,*">
                    <StackPanel Grid.Column="0" Spacing="5" Margin="0,0,10,0">
                        <TextBlock Text="Длительность (мин)" Foreground="#7F8C8D" FontWeight="SemiBold"/>
                        <NumericUpDown x:Name="DurationNumeric" Minimum="15" Maximum="300" Increment="5" Value="60"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="5" Margin="5,0,5,0">
                        <TextBlock Text="Кол-во мест" Foreground="#7F8C8D" FontWeight="SemiBold"/>
                        <NumericUpDown x:Name="MaxParticipantsNumeric" Minimum="1" Maximum="100" Increment="1" Value="20"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Spacing="5" Margin="10,0,0,0">
                        <TextBlock Text="Цена (₽)" Foreground="#7F8C8D" FontWeight="SemiBold"/>
                        <NumericUpDown x:Name="PriceNumeric" Minimum="0" Maximum="100000" Increment="100" Value="500"/>
                    </StackPanel>
                </Grid>

                <CheckBox x:Name="IsActiveCheckBox" Content="Активна (отображается у клиентов)" 
                          IsChecked="True" Margin="0,10,0,0" FontSize="15"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20" Margin="0,25,0,20">
                    <Button Content="Создать" 
                            Width="160" Height="45"
                            Background="#27AE60" Foreground="White"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                            FontSize="16" FontWeight="Bold" CornerRadius="8"
                            Click="AddButton_Click"/>
                    
                    <Button Content="Отмена" 
                            Width="160" Height="45"
                            Background="#95A5A6" Foreground="White"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                            FontSize="16" CornerRadius="8"
                            Click="CancelButton_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </ScrollViewer>
</Window>